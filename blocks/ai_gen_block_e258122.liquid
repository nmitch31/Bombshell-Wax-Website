{% doc %}
  @prompt
    a scrollable row of products with a header above containing a title and image left of the title, with a subheader below for paragraph text. Can you make the image dimensions 100px by 100px for the logo left of the title, make the image dimensions responsive to the image uploaded, with max height 200 and max width 500, can you put the subheader below both the image and title
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-row-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-row-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-row-header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-product-row-header-top-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 16px;
  }

  .ai-product-row-logo-{{ ai_gen_id }} {
    flex-shrink: 0;
    max-width: 500px;
    max-height: 200px;
    border-radius: {{ block.settings.logo_border_radius }}px;
    overflow: hidden;
  }

  .ai-product-row-logo-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    max-width: 500px;
    max-height: 200px;
  }

  .ai-product-row-logo-placeholder-{{ ai_gen_id }} {
    width: 100px;
    height: 100px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-row-logo-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    color: #ccc;
  }

  .ai-product-row-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    line-height: 1.2;
  }

  .ai-product-row-subheader-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.subheader_size }}px;
    color: {{ block.settings.subheader_color }};
    line-height: 1.4;
  }

  .ai-product-row-products-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-product-row-scroll-container-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: thin;
    scrollbar-color: {{ block.settings.scrollbar_color }} transparent;
    padding-bottom: 10px;
  }

  .ai-product-row-scroll-container-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 6px;
  }

  .ai-product-row-scroll-container-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: transparent;
  }

  .ai-product-row-scroll-container-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background-color: {{ block.settings.scrollbar_color }};
    border-radius: 3px;
  }

  .ai-product-row-grid-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.product_gap }}px;
    padding: 0;
    min-width: max-content;
  }

  .ai-product-row-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.product_width }}px;
    background-color: {{ block.settings.product_card_bg }};
    border-radius: {{ block.settings.product_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-product-row-item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-product-row-image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.product_image_height }}px;
    overflow: hidden;
  }

  .ai-product-row-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-product-row-item-{{ ai_gen_id }}:hover .ai-product-row-image-{{ ai_gen_id }} img {
    transform: scale(1.05);
  }

  .ai-product-row-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-row-image-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    color: #ccc;
  }

  .ai-product-row-content-{{ ai_gen_id }} {
    padding: 16px;
  }

  .ai-product-row-product-title-{{ ai_gen_id }} {
    margin: 0 0 8px 0;
    font-size: 16px;
    font-weight: 500;
    color: {{ block.settings.product_title_color }};
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-product-row-product-price-{{ ai_gen_id }} {
    margin: 0;
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.product_price_color }};
  }

  .ai-product-row-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-product-row-empty-state-{{ ai_gen_id }} h3 {
    margin: 0 0 8px 0;
    font-size: 18px;
    color: #333;
  }

  @media screen and (max-width: 768px) {
    .ai-product-row-header-top-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .ai-product-row-logo-{{ ai_gen_id }} {
      max-width: 300px;
      max-height: 120px;
    }

    .ai-product-row-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-product-row-subheader-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheader_size | times: 0.9 }}px;
    }

    .ai-product-row-item-{{ ai_gen_id }} {
      width: {{ block.settings.product_width | times: 0.8 }}px;
    }

    .ai-product-row-image-{{ ai_gen_id }} {
      height: {{ block.settings.product_image_height | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-product-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-row-container-{{ ai_gen_id }}">
    <div class="ai-product-row-header-{{ ai_gen_id }}">
      <div class="ai-product-row-header-top-{{ ai_gen_id }}">
        <div class="ai-product-row-logo-{{ ai_gen_id }}">
          {% if block.settings.logo_image %}
            <img
              src="{{ block.settings.logo_image | image_url: width: 500 }}"
              alt="{{ block.settings.logo_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.logo_image.width }}"
              height="{{ block.settings.logo_image.height }}"
            >
          {% else %}
            <div class="ai-product-row-logo-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        
        {% if block.settings.title != blank %}
          <h2 class="ai-product-row-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
      </div>
      
      {% if block.settings.subheader != blank %}
        <div class="ai-product-row-subheader-{{ ai_gen_id }}">{{ block.settings.subheader }}</div>
      {% endif %}
    </div>

    <div class="ai-product-row-products-{{ ai_gen_id }}">
      {% if block.settings.collection != blank and block.settings.collection.products.size > 0 %}
        <div class="ai-product-row-scroll-container-{{ ai_gen_id }}">
          <div class="ai-product-row-grid-{{ ai_gen_id }}">
            {% for product in block.settings.collection.products limit: block.settings.products_limit %}
              <div class="ai-product-row-item-{{ ai_gen_id }}">
                <a href="{{ product.url }}" class="ai-product-row-image-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 400 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      loading="lazy"
                      width="{{ block.settings.product_width }}"
                      height="{{ block.settings.product_image_height }}"
                    >
                  {% else %}
                    <div class="ai-product-row-image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </a>
                
                <div class="ai-product-row-content-{{ ai_gen_id }}">
                  <h3 class="ai-product-row-product-title-{{ ai_gen_id }}">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h3>
                  <div class="ai-product-row-product-price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      {% else %}
        <div class="ai-product-row-empty-state-{{ ai_gen_id }}">
          <h3>No products to display</h3>
          <p>Select a collection to show products in this row.</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Scrollable product row",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_border_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Logo border radius",
      "default": 8
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Featured Products"
    },
    {
      "type": "textarea",
      "id": "subheader",
      "label": "Subheader text",
      "default": "Discover our carefully curated selection of premium products."
    },
    {
      "type": "range",
      "id": "header_spacing",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Header bottom spacing",
      "default": 30
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 4,
      "max": 20,
      "step": 1,
      "label": "Products to show",
      "default": 12
    },
    {
      "type": "range",
      "id": "product_width",
      "min": 200,
      "max": 350,
      "step": 10,
      "unit": "px",
      "label": "Product card width",
      "default": 280
    },
    {
      "type": "range",
      "id": "product_image_height",
      "min": 200,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Product image height",
      "default": 280
    },
    {
      "type": "range",
      "id": "product_gap",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Gap between products",
      "default": 20
    },
    {
      "type": "range",
      "id": "product_border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Product card border radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "subheader_color",
      "label": "Subheader color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "product_card_bg",
      "label": "Product card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Product title color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "product_price_color",
      "label": "Product price color",
      "default": "#FF871D"
    },
    {
      "type": "color",
      "id": "scrollbar_color",
      "label": "Scrollbar color",
      "default": "#cccccc"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 32
    },
    {
      "type": "range",
      "id": "subheader_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheader size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Section padding",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Scrollable product row"
    }
  ]
}
{% endschema %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-collection-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-collection-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-collection-title-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: 600;
  }

  .ai-product-collection-tabs-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 30px;
    flex-wrap: wrap;
  }

  .ai-product-collection-tab-{{ ai_gen_id }} {
    padding: 12px 24px;
    background-color: {{ block.settings.tab_bg_color }};
    color: {{ block.settings.tab_text_color }};
    border: 2px solid {{ block.settings.tab_border_color }};
    border-radius: {{ block.settings.tab_border_radius }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-weight: 500;
    text-decoration: none;
    display: inline-block;
  }

  .ai-product-collection-tab-{{ ai_gen_id }}:hover,
  .ai-product-collection-tab-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.tab_active_bg_color }};
    color: {{ block.settings.tab_active_text_color }};
    border-color: {{ block.settings.tab_active_border_color }};
  }

  .ai-bulk-pricing-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 20px;
    font-size: {{ block.settings.bulk_header_size }}px;
    color: {{ block.settings.bulk_header_color }};
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-bulk-pricing-chart-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .ai-bulk-pricing-item-{{ ai_gen_id }} {
    text-align: center;
    min-width: 80px;
  }

  .ai-bulk-pricing-square-{{ ai_gen_id }} {
    width: {{ block.settings.bulk_square_size }}px;
    height: {{ block.settings.bulk_square_size }}px;
    background-color: {{ block.settings.bulk_square_color }};
    border: 2px solid {{ block.settings.bulk_square_border_color }};
    border-radius: {{ block.settings.bulk_square_border_radius }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    font-weight: 600;
    color: {{ block.settings.bulk_square_text_color }};
    font-size: 14px;
    gap: 2px;
  }

  .ai-bulk-square-quantity-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 700;
  }

  .ai-bulk-square-savings-{{ ai_gen_id }} {
    font-size: 11px;
    font-weight: 600;
    color: {{ block.settings.bulk_savings_color }};
  }

  .ai-product-collection-content-{{ ai_gen_id }} {
    display: none;
  }

  .ai-product-collection-content-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-products-grid-{{ ai_gen_id }} {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(var(--ai-products-per-row-{{ ai_gen_id }}), 1fr);
  }

  .ai-product-card-{{ ai_gen_id }} {
    text-align: center;
    background-color: {{ block.settings.product_card_bg_color }};
    border-radius: {{ block.settings.product_card_border_radius }}px;
    padding: 15px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
  }

  .ai-product-image-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: {{ block.settings.product_image_border_radius }}px;
    margin-bottom: 15px;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.product_image_border_radius }}px;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.5;
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin-bottom: 8px;
    font-weight: 500;
    text-decoration: none;
    display: block;
  }

  .ai-product-title-{{ ai_gen_id }}:hover {
    color: {{ block.settings.product_title_hover_color }};
  }

  .ai-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
    font-weight: 600;
  }

  .ai-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-empty-state-{{ ai_gen_id }} h3 {
    margin-bottom: 10px;
    color: #333;
  }

  @media screen and (max-width: 768px) {
    .ai-products-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(var(--ai-products-per-row-mobile-{{ ai_gen_id }}), 1fr);
    }

    .ai-product-collection-tabs-{{ ai_gen_id }} {
      gap: 10px;
    }

    .ai-product-collection-tab-{{ ai_gen_id }} {
      padding: 10px 16px;
      font-size: 14px;
    }

    .ai-bulk-pricing-chart-{{ ai_gen_id }} {
      gap: 15px;
    }

    .ai-bulk-pricing-header-{{ ai_gen_id }} {
      font-size: {{ block.settings.bulk_header_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-products-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(1, 1fr);
    }
  }
{% endstyle %}

<product-collection-tabs-{{ ai_gen_id }}
  class="ai-product-collection-{{ ai_gen_id }}"
  style="
    --ai-products-per-row-{{ ai_gen_id }}: {{ block.settings.products_per_row }};
    --ai-products-per-row-mobile-{{ ai_gen_id }}: {{ block.settings.products_per_row_mobile }};
  "
  {{ block.shopify_attributes }}
>
  <div class="ai-product-collection-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <h2 class="ai-product-collection-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    {% endif %}

    <div class="ai-product-collection-tabs-{{ ai_gen_id }}">
  {% for i in (1..5) %}
    {% liquid
      assign tab_enabled_key = 'tab_' | append: i | append: '_enabled'
      assign tab_title_key = 'tab_' | append: i | append: '_title'
      assign tab_enabled = block.settings[tab_enabled_key]
      assign tab_title = block.settings[tab_title_key]
    %}
    {% if tab_enabled and tab_title != blank %}
      <button
        class="ai-product-collection-tab-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
        data-tab="{{ i }}"
        aria-label="View {{ tab_title }} products"
      >
        {{ tab_title }}
      </button>
    {% endif %}
  {% endfor %}
</div>

{% for i in (1..5) %}
  {% liquid
    assign tab_enabled_key = 'tab_' | append: i | append: '_enabled'
    assign tab_title_key = 'tab_' | append: i | append: '_title'
    assign tab_enabled = block.settings[tab_enabled_key]
    assign tab_title = block.settings[tab_title_key]
  %}
  {% if tab_enabled and tab_title != blank %}
    <div class="ai-bulk-pricing-chart-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-tab-content="{{ i }}">
      <h3 class="ai-bulk-pricing-header-{{ ai_gen_id }}">Bulk Pricing for {{ tab_title }}</h3>

      {% for j in (1..6) %}
        {% liquid
          assign bulk_enabled_key = 'bulk_' | append: i | append: '_' | append: j | append: '_enabled'
          assign bulk_size_key = 'bulk_' | append: i | append: '_' | append: j | append: '_size'
          assign bulk_savings_key = 'bulk_' | append: i | append: '_' | append: j | append: '_savings'
          assign bulk_enabled = block.settings[bulk_enabled_key]
          assign bulk_size = block.settings[bulk_size_key]
          assign bulk_savings = block.settings[bulk_savings_key]
        %}
        {% if bulk_enabled and bulk_size != blank %}
          <div class="ai-bulk-pricing-item-{{ ai_gen_id }}">
            <div class="ai-bulk-pricing-square-{{ ai_gen_id }}">
              <div class="ai-bulk-square-quantity-{{ ai_gen_id }}">
                {{ bulk_size }}
              </div>
              {% if bulk_savings != blank %}
                <div class="ai-bulk-square-savings-{{ ai_gen_id }}">
                  {{ bulk_savings }}% off
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
{% endfor %}


    {% for i in (1..5) %}
      {% liquid
        assign tab_enabled_key = 'tab_' | append: i | append: '_enabled'
        assign tab_collection_key = 'tab_' | append: i | append: '_collection'
        assign tab_enabled = block.settings[tab_enabled_key]
        assign tab_collection = block.settings[tab_collection_key]
      %}
      {% if tab_enabled %}
        <div
          class="ai-product-collection-content-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
          data-content="{{ i }}"
        >
          {% if tab_collection != blank and tab_collection.products.size > 0 %}
            <div class="ai-products-grid-{{ ai_gen_id }}">
              {% for product in tab_collection.products limit: block.settings.products_limit %}
                <div class="ai-product-card-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 300 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="ai-product-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="300"
                      height="200"
                    >
                  {% else %}
                    <div class="ai-product-image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-apparel-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}

                  <a href="{{ product.url }}" class="ai-product-title-{{ ai_gen_id }}">
                    {{ product.title }}
                  </a>

                  <div class="ai-product-price-{{ ai_gen_id }}">
                    {% if product.compare_at_price > product.price %}
                      <span style="text-decoration: line-through; opacity: 0.7; margin-right: 8px;">
                        {{ product.compare_at_price | money }}
                      </span>
                    {% endif %}
                    {{ product.price | money }}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% else %}
            <div class="ai-empty-state-{{ ai_gen_id }}">
              <h3>No products found</h3>
              <p>Please select a collection for this tab to display products.</p>
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</product-collection-tabs-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCollectionTabs{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tabs = this.querySelectorAll('.ai-product-collection-tab-{{ ai_gen_id }}');
        this.contents = this.querySelectorAll('.ai-product-collection-content-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.tabs.forEach((tab) => {
          tab.addEventListener('click', (e) => {
            e.preventDefault();
            const tabId = tab.getAttribute('data-tab');
            this.switchTab(tabId);
          });
        });
      }

      switchTab(tabId) {
        this.tabs.forEach((tab) => {
          tab.classList.remove('active');
          if (tab.getAttribute('data-tab') === tabId) {
            tab.classList.add('active');
          }
        });

        this.contents.forEach((content) => {
          content.classList.remove('active');
          if (content.getAttribute('data-content') === tabId) {
            content.classList.add('active');
          }
        });
      }
    }

    customElements.define('product-collection-tabs-{{ ai_gen_id }}', ProductCollectionTabs{{ ai_gen_id }});
  })();
</script>


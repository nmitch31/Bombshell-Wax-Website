{% doc %}
  @prompt
    A block to write HTML code
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-html-block-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    {% if block.settings.max_width_enabled %}
      max-width: {{ block.settings.max_width }}px;
      margin: 0 auto;
    {% endif %}
  }

  .ai-html-content-{{ ai_gen_id }} {
    width: 100%;
    overflow-wrap: break-word;
    word-wrap: break-word;
  }

  .ai-html-empty-state-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    background-color: #f8f9fa;
    border: 2px dashed #dee2e6;
    border-radius: 8px;
    color: #6c757d;
  }

  .ai-html-empty-state-{{ ai_gen_id }} h3 {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 600;
    color: #495057;
  }

  .ai-html-empty-state-{{ ai_gen_id }} p {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
  }

  .ai-html-empty-state-{{ ai_gen_id }} svg {
    width: 48px;
    height: 48px;
    margin-bottom: 16px;
    opacity: 0.5;
  }

  @media screen and (max-width: 749px) {
    .ai-html-block-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div
  class="ai-html-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.html_content != blank %}
    <div class="ai-html-content-{{ ai_gen_id }}">
      {{ block.settings.html_content }}
    </div>
  {% else %}
    <div class="ai-html-empty-state-{{ ai_gen_id }}">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
      </svg>
      <h3>Custom HTML Block</h3>
      <p>Add your custom HTML code in the block settings to display content here.<br>You can include any valid HTML, CSS, or JavaScript.</p>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Custom HTML",
  "settings": [
    {
      "type": "header",
      "content": "HTML Content"
    },
    {
      "type": "html",
      "id": "html_content",
      "label": "HTML code",
      "info": "Add your custom HTML, CSS, or JavaScript code here. Make sure your code is valid and secure."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "max_width_enabled",
      "label": "Limit maximum width",
      "default": false
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 300,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 800
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Custom HTML"
    }
  ],
  "tag": null
}
{% endschema %}
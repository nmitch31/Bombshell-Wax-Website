{% doc %}
  @prompt
    a block to write html code
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-html-code-block-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-html-code-block__header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.spacing }}px;
  }

  .ai-html-code-block__title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 8px 0;
    font-weight: 600;
  }

  .ai-html-code-block__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.description_size }}px;
    margin: 0;
    opacity: 0.8;
  }

  .ai-html-code-block__content-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
  }

  .ai-html-code-block__content-{{ ai_gen_id }} * {
    max-width: 100%;
  }

  .ai-html-code-block__content-{{ ai_gen_id }} img {
    height: auto;
    display: block;
  }

  .ai-html-code-block__content-{{ ai_gen_id }} iframe {
    width: 100%;
    max-width: 100%;
  }

  .ai-html-code-block__empty-state-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    background-color: #f8f9fa;
    border: 2px dashed #dee2e6;
    border-radius: 8px;
    color: #6c757d;
  }

  .ai-html-code-block__empty-icon-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    margin: 0 auto 16px;
    opacity: 0.5;
  }

  .ai-html-code-block__empty-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px 0;
    color: #495057;
  }

  .ai-html-code-block__empty-description-{{ ai_gen_id }} {
    font-size: 14px;
    margin: 0;
    color: #6c757d;
  }

  @media screen and (max-width: 749px) {
    .ai-html-code-block-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.7 | round }}px;
    }

    .ai-html-code-block__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 | round }}px;
    }

    .ai-html-code-block__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 | round }}px;
    }
  }
{% endstyle %}

<div
  class="ai-html-code-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.title != blank or block.settings.description != blank %}
    <div class="ai-html-code-block__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-html-code-block__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.description != blank %}
        <p class="ai-html-code-block__description-{{ ai_gen_id }}">{{ block.settings.description }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-html-code-block__content-{{ ai_gen_id }}">
    {% if block.settings.html_code != blank %}
      {{ block.settings.html_code }}
    {% else %}
      <div class="ai-html-code-block__empty-state-{{ ai_gen_id }}">
        <div class="ai-html-code-block__empty-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16,18 22,12 16,6"></polyline>
            <polyline points="8,6 2,12 8,18"></polyline>
          </svg>
        </div>
        <h3 class="ai-html-code-block__empty-title-{{ ai_gen_id }}">Add your HTML code</h3>
        <p class="ai-html-code-block__empty-description-{{ ai_gen_id }}">Use the HTML code setting to add custom content, embed videos, or include third-party widgets</p>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "HTML code block",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "html",
      "id": "html_code",
      "label": "HTML code"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e5e5e5"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Border width",
      "default": 0
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Header spacing",
      "default": 16
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 24
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "HTML code block"
    }
  ]
}
{% endschema %}
{% doc %}
  @prompt
    Create a responsive banner section with a four-column background where each column has a different customizable color. On the left side, display text content. On the right side, stack two images vertically with no styling or backgrounds. Position the top image so it extends slightly above the banner's top edge, and the bottom image so it extends slightly below the banner's bottom edge. On mobile devices, arrange the layout vertically: top image extending above the section, text content in the middle, and bottom image extending below the section., On mobile devices, arrange the layout vertically: top image extending above the section, text content in the middle, and bottom image extending below the section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .ai-banner-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    position: relative;
    min-height: {{ block.settings.banner_height }}px;
  }

  .ai-banner-column-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-banner-column-{{ ai_gen_id }}:nth-child(1) {
    background-color: {{ block.settings.column_color_1 }};
  }

  .ai-banner-column-{{ ai_gen_id }}:nth-child(2) {
    background-color: {{ block.settings.column_color_2 }};
  }

  .ai-banner-column-{{ ai_gen_id }}:nth-child(3) {
    background-color: {{ block.settings.column_color_3 }};
  }

  .ai-banner-column-{{ ai_gen_id }}:nth-child(4) {
    background-color: {{ block.settings.column_color_4 }};
  }

  .ai-banner-content-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    padding: 60px 40px;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    z-index: 2;
  }

  .ai-banner-text-section-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
  }

  .ai-banner-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-banner-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-banner-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-banner-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 30px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: background-color 0.3s ease;
    align-self: flex-start;
  }

  .ai-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-banner-images-section-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .ai-banner-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-banner-image-wrapper-{{ ai_gen_id }}--top {
    margin-top: -{{ block.settings.image_overflow }}px;
  }

  .ai-banner-image-wrapper-{{ ai_gen_id }}--bottom {
    margin-bottom: -{{ block.settings.image_overflow }}px;
  }

  .ai-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-banner-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-banner-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  @media screen and (max-width: 768px) {
    .ai-banner-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
    }

    .ai-banner-container-{{ ai_gen_id }} {
      display: none;
    }

    .ai-banner-content-wrapper-{{ ai_gen_id }} {
      position: static;
      display: flex;
      flex-direction: column;
      gap: 0;
      padding: 0;
      max-width: 100%;
    }

    .ai-banner-text-section-{{ ai_gen_id }} {
      order: 2;
      padding: 40px 20px;
      background-color: {{ block.settings.mobile_text_bg_color }};
    }

    .ai-banner-images-section-{{ ai_gen_id }} {
      display: contents;
    }

    .ai-banner-image-wrapper-{{ ai_gen_id }}--top {
      order: 1;
      margin-top: -{{ block.settings.mobile_image_overflow }}px;
      margin-bottom: 0;
    }

    .ai-banner-image-wrapper-{{ ai_gen_id }}--bottom {
      order: 3;
      margin-bottom: -{{ block.settings.mobile_image_overflow }}px;
      margin-top: 0;
    }

    .ai-banner-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-banner-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-banner-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-banner-container-{{ ai_gen_id }}">
    <div class="ai-banner-column-{{ ai_gen_id }}"></div>
    <div class="ai-banner-column-{{ ai_gen_id }}"></div>
    <div class="ai-banner-column-{{ ai_gen_id }}"></div>
    <div class="ai-banner-column-{{ ai_gen_id }}"></div>
  </div>

  <div class="ai-banner-content-wrapper-{{ ai_gen_id }}">
    <div class="ai-banner-images-section-{{ ai_gen_id }}">
      <div class="ai-banner-image-wrapper-{{ ai_gen_id }} ai-banner-image-wrapper-{{ ai_gen_id }}--top">
        {% if block.settings.top_image %}
          <img
            src="{{ block.settings.top_image | image_url: width: 800 }}"
            alt="{{ block.settings.top_image.alt | escape }}"
            class="ai-banner-image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.top_image.width }}"
            height="{{ block.settings.top_image.height }}"
          >
        {% else %}
          <div class="ai-banner-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-banner-image-wrapper-{{ ai_gen_id }} ai-banner-image-wrapper-{{ ai_gen_id }}--bottom">
        {% if block.settings.bottom_image %}
          <img
            src="{{ block.settings.bottom_image | image_url: width: 800 }}"
            alt="{{ block.settings.bottom_image.alt | escape }}"
            class="ai-banner-image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.bottom_image.width }}"
            height="{{ block.settings.bottom_image.height }}"
          >
        {% else %}
          <div class="ai-banner-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-banner-text-section-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-banner-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <h3 class="ai-banner-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</h3>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-banner-description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-banner-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Four column banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "banner_height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Banner height",
      "default": 500
    },
    {
      "type": "range",
      "id": "image_overflow",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Image overflow (desktop)",
      "default": 50
    },
    {
      "type": "range",
      "id": "mobile_image_overflow",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Image overflow (mobile)",
      "default": 30
    },
    {
      "type": "header",
      "content": "Background colors"
    },
    {
      "type": "color",
      "id": "column_color_1",
      "label": "Column 1",
      "default": "#f0f0f0"
    },
    {
      "type": "color",
      "id": "column_color_2",
      "label": "Column 2",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "column_color_3",
      "label": "Column 3",
      "default": "#d0d0d0"
    },
    {
      "type": "color",
      "id": "column_color_4",
      "label": "Column 4",
      "default": "#c0c0c0"
    },
    {
      "type": "color",
      "id": "mobile_text_bg_color",
      "label": "Mobile text background",
      "default": "#f0f0f0"
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Our Store"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 48
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover amazing products"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Subheading size",
      "default": 24
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Shop our latest collection and find the perfect items for you.</p>"
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 4
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Hover background color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "top_image",
      "label": "Top image"
    },
    {
      "type": "image_picker",
      "id": "bottom_image",
      "label": "Bottom image"
    }
  ],
  "presets": [
    {
      "name": "Four column banner"
    }
  ]
}
{% endschema %}

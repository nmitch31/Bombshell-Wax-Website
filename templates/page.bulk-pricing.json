custom_css":[".section-collection-v2 {box-shadow: 0px 0px 0px 0px !important;}"],"name":"Header button","settings":{"bg_section":"#ffffff","title_heading":"Apply to be considered for enrollment.","color_title":"#000000","sub_heading":"Access exclusive tiered rates, priority fulfillment, and dedicated support.","color_sub_heading":"#666666","link-title":"Submit","link_url":"https:\/\/forms.gle\/mZCjmyQytFcqiXPy7","button_bg_color":"#e272a3","button_hover_color":"#333333","button_font_color":"#ffffff","button_hover_font_color":"#ffffff"}},"about_template_v2_Nzm4Nm":{"type":"about-template-v2","disabled":true,"name":"Address","settings":{"enable_slide":false,"enable_about_top":true,"title_abouttop":"","description_abouttop":"<b style=\"font-size: 18px;\">Tier Structure Overview<\/b>\n\n<div style=\"margin-top: 14px; border-left: 4px solid #e272a3; padding-left: 16px;\">\n\n  <p style=\"margin: 0 0 14px; font-size: 16.5px; line-height: 1.7;\">\n    <b>Tier 1 — Professional Online Pricing<\/b><br>\n    Standard professional pricing available directly through bombshellwax.com.<br>\n    <i>No contract. Immediate access.<\/i>\n  <\/p>\n\n  <p style=\"margin: 0 0 14px; font-size: 16.5px; line-height: 1.7;\">\n    <b>Tier 2 — Pro Bulk Pricing<\/b><br>\n    Contracted bulk pricing for high-volume single locations and multi-suite studios.<br>\n    <i>Lower cost per pound with dedicated support.<\/i>\n  <\/p>\n\n  <p style=\"margin: 0 0 14px; font-size: 16.5px; line-height: 1.7;\">\n    <b>Tier 3 — Multi-Unit & Enterprise Pricing<\/b><br>\n    Deep volume pricing with enterprise-level account support for multi-location brands, franchises, and schools.<br>\n    <i>Priority allocation and centralized logistics.<\/i>\n  <\/p>\n\n  <p style=\"margin: 0; font-size: 16.5px; line-height: 1.7;\">\n    <b>Tier 4 — Private Label & Custom Solutions<\/b><br>\n    Custom formulations, branding, and long-term pricing structures for private-label partners.<br>\n    <i>Strategic manufacturing and brand development.<\/i><\/p>\n<\/div>","button_about_top":"","link_abouttop":"","enable_video":false,"url_section_video":"","enable_teams":false,"title_teams":"","description_teams":"","enable_store":false,"title_store":"","description_store":"","urlimage_store1":"shopify:\/\/collections\/all","urlimage_store2":"shopify:\/\/collections\/all","urlimage_store3":"shopify:\/\/collections\/all","enable_address":false}},"faq_template_ACwhDR":{"type":"FAQ-template","blocks":{"faq_left_7AKRKU":{"type":"faq_left","settings":{"block_title_question":"What are the Volume Pricing Tiers?","block_description_question":"4 Tiers:\n<br>\nWebsite Direct - You are here! We already have bulk pricing tiered with up to 33% off 46 lbs. of wax. See the chart on <a href=\"bombshellwax.com\">our homepage<\/a> for more details.\n<br>\nPro Bulk - Contracted lower price-per-pound bulk pricing for high-volume single locations, multi-suite studios, and solo owners who team up with friends to achieve better pricing! Minimum order quantity of 230-672 lbs. per month.\n<br>\nEnterprise\/Franchise - Deep volume pricing for multi-location brands, franchises, and schools. Minimum order quantity of 720-1,680 lbs. per month.\n<br>\nPrivate Label - Long-term pricing structures for those looking to private label, including strategic manufacturing and brand development. Minimum order quantity of 1,200 lbs. per month."}},"faq_left_8jYNUg":{"type":"faq_left","settings":{"block_title_question":"What are the Bulk Hard & Soft Wax Options?","block_description_question":"All Hard Wax and Soft Wax Offerings are available in bulk. Hard wax comes in 2lb bags, Soft Wax comes in 15oz cans (fits in standard wax warmers, melt-in-can). Combinations are welcome.\n<br>\n<a href=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0347\/0934\/0300\/files\/Hard_Wax_Product_Card.pdf?v=1769622220\" target=\"_blank\">Click for more details on each hard wax<\/a>\n<br>\n<a href=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0347\/0934\/0300\/files\/Soft_Wax_Product_Card.pdf?v=1769622220\" target=\"_blank\">Click for more details on each soft wax<\/a>"}},"faq_left_PxewXH":{"type":"faq_left","settings":{"block_title_question":"What is Predictive Order Scheduling","block_description_question":"We take care of your order cycle for you! If you typically order wax every 2 weeks, every month, or whatever cadence it may be, we will keep track of when you need your next order and reach out to confirm or modify before shipping!"}},"faq_left_39XHyX":{"type":"faq_left","settings":{"block_title_question":"What is a Dedicated Account Manager?","block_description_question":"Direct line of communication with us, get real people on the phone, no AI ! And we answer promptly! (Email and Phone)"}},"faq_left_4gxnbf":{"type":"faq_left","settings":{"block_title_question":"What is Centralized Billing?","block_description_question":"All locations billed to one central profile we will have on file. Keep track of all your locations with only one account."}},"faq_left_49jCUt":{"type":"faq_left","settings":{"block_title_question":"What is Logistics Coordination?","block_description_question":"We will deal with coordinating with trucking\/shipping companies, keeping track of your product. Including dealing with freight and any complications."}},"faq_left_9Whw9H":{"type":"faq_left","settings":{"block_title_question":"What is Formula & Labeling Consultation?","block_description_question":"Private label the world's best wax under your brand's name! Potential for discussion of custom-made wax formulas, tailored exactly to your needs and specifications."}},"faq_left_RRzNyR":{"type":"faq_left","settings":{"block_title_question":"Refunds and Returns?","block_description_question":"Provided the wax arrives in proper condition and amounts, no refunds and returns shall be issued. In the case of shipping mishandles, broken bags, and missing wax, replacements will be issued (submit photos and claims to account manager)."}}},"block_order":["faq_lef
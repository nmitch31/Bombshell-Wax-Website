{% comment %}
  ══════════════════════════════════════════════════════════════════
  Bombshell Wax – Customer Account Page
  File: templates/customers/account.liquid

  Integrations:
    • Lootly Loyalty & Referrals – link goes to /pages/lootly-rewards
    • Shopper Approved – "Write a Review" link per product in orders,
      using the SA jumpcode to scroll to the reviews widget on the
      product page (token: cbfwY6gT, site ID: 35487)
    • PayWhirl – subscription portal via /a/paywhirl iframe

  Tab routing: driven by URL #hash; back-button safe.
  ══════════════════════════════════════════════════════════════════
{% endcomment %}

{% assign lootly_api_key     = 'YOUR_LOOTLY_API_KEY' %}
{% assign lootly_shop_id     = 'YOUR_LOOTLY_SHOP_ID' %}
{% assign lootly_shop_domain = 'https://YOUR_SHOP_DOMAIN.myshopify.com' %}
{% assign sa_site_id = '35487' %}
{% assign sa_token   = 'cbfwY6gT' %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap');

  :root {
    --pink:       #e272a3;
    --pink-light: #fce8f1;
    --pink-hover: #E15F8D;
    --dark:       #1a1a2e;
    --mid:        #6b6b80;
    --border:     #eee;
    --bg:         #fafafa;
    --white:      #ffffff;
    --radius:     14px;
    --shadow:     0 4px 24px rgba(232,80,138,.10);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--dark); }

  .bw-account { max-width: 1140px; margin: 32px auto 80px; padding: 0 16px; }

  .bw-account__heading {
    font-family: 'Nunito', sans-serif;
    font-style: italic;
    font-size: clamp(1.4rem, 4vw, 2.2rem);
    color: var(--dark);
    margin-bottom: 20px;
    letter-spacing: -.5px;
  }
  .bw-account__heading em { font-style: normal; color: var(--pink); }

  /* ── Two-column layout ── */
  .bw-account__layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 20px;
    align-items: start;
  }

  /* ── SIDEBAR ── */
  .bw-account__sidebar {
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 24px 16px;
    position: sticky;
    top: 16px;
  }

  .bw-brand {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 24px; padding-bottom: 18px;
    border-bottom: 1px solid var(--border);
  }
  .bw-brand__avatar {
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--pink); color: var(--white);
    font-weight: 700; font-size: .85rem; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .bw-brand__name { font-family: 'Nunito', sans-serif; font-size: .95rem; font-weight: 700; line-height: 1.2; }
  .bw-brand__email { font-size: .72rem; color: var(--mid); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 144px; }

  .bw-nav { list-style: none; }
  .bw-nav__item + .bw-nav__item { margin-top: 3px; }
  .bw-nav__link {
    display: flex; align-items: center; gap: 9px;
    padding: 9px 12px; border-radius: 10px;
    font-size: .85rem; font-weight: 500; color: var(--mid);
    text-decoration: none; transition: background .18s, color .18s; cursor: pointer;
    white-space: nowrap;
  }
  .bw-nav__link svg { flex-shrink: 0; opacity: .7; transition: opacity .18s; }
  .bw-nav__link:hover, .bw-nav__link.is-active { background: var(--pink-light); color: var(--pink); }
  .bw-nav__link.is-active svg, .bw-nav__link:hover svg { opacity: 1; }
  .bw-nav__link.is-active { font-weight: 600; border-left: 3px solid var(--pink); padding-left: 9px; }
  .bw-nav__divider { height: 1px; background: var(--border); margin: 12px 0; }
  .bw-nav__logout { color: #c0392b !important; }
  .bw-nav__logout:hover { background: #fdecea !important; }

  /* ── MOBILE NAV (bottom tab bar) ── */
  .bw-mobile-nav {
    display: none;
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: var(--white);
    border-top: 1px solid var(--border);
    box-shadow: 0 -4px 20px rgba(0,0,0,.08);
    z-index: 100;
    padding: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .bw-mobile-nav__inner {
    display: flex;
    min-width: max-content;
    padding: 0 4px;
  }
  .bw-mobile-nav__btn {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 3px; padding: 8px 14px 10px;
    font-size: .62rem; font-weight: 500; color: var(--mid);
    text-decoration: none; border: none; background: none;
    cursor: pointer; font-family: inherit;
    transition: color .18s; min-width: 60px; white-space: nowrap;
  }
  .bw-mobile-nav__btn svg { opacity: .6; transition: opacity .18s; }
  .bw-mobile-nav__btn.is-active { color: var(--pink); }
  .bw-mobile-nav__btn.is-active svg { opacity: 1; }
  .bw-mobile-nav__btn--logout { color: #c0392b; }

  /* ── MAIN PANEL ── */
  .bw-account__main {
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 32px 36px;
    min-height: 480px;
  }

  .bw-panel { display: none; }
  .bw-panel.is-active { display: block; animation: fadeUp .28s ease both; }
  @keyframes fadeUp { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

  .bw-panel__title { font-family: 'Nunito', sans-serif; font-size: 1.4rem; margin-bottom: 6px; }
  .bw-panel__title em { font-style: italic; color: var(--pink); }
  .bw-panel__rule { height: 2px; background: linear-gradient(90deg, var(--pink), transparent); border: none; margin-bottom: 24px; border-radius: 2px; }

  /* ── HOME ── */
  .bw-welcome {
    display: flex; align-items: center; gap: 14px;
    background: var(--pink-light); border-radius: 12px;
    padding: 18px 22px; margin-bottom: 24px;
  }
  .bw-welcome__avatar {
    width: 48px; height: 48px; border-radius: 50%;
    background: var(--pink); color: var(--white);
    font-weight: 700; font-size: 1rem;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .bw-welcome__text h2 { font-family: 'Nunito', sans-serif; font-size: 1.05rem; }
  .bw-welcome__text p { font-size: .8rem; color: var(--mid); margin-top: 2px; }

  .bw-home-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 14px; }
  .bw-summary-card {
    border: 1px solid var(--border); border-radius: 12px; padding: 18px;
    cursor: pointer; transition: border-color .2s, box-shadow .2s, transform .18s;
    text-decoration: none; color: inherit; display: block;
  }
  .bw-summary-card:hover { border-color: var(--pink); box-shadow: 0 6px 20px rgba(232,80,138,.14); transform: translateY(-2px); }
  .bw-summary-card__icon { width: 38px; height: 38px; border-radius: 9px; background: var(--pink-light); display: flex; align-items: center; justify-content: center; margin-bottom: 12px; color: var(--pink); }
  .bw-summary-card__label { font-family: 'Nunito', sans-serif; font-style: italic; font-size: .95rem; font-weight: 700; margin-bottom: 5px; }
  .bw-summary-card__desc { font-size: .75rem; color: var(--mid); line-height: 1.5; }

  /* ── ORDERS ── */
  .bw-orders-empty, .bw-generic-empty { text-align: center; padding: 50px 20px; color: var(--mid); }
  .bw-orders-empty__icon { font-size: 2.4rem; margin-bottom: 12px; }
  .bw-order-list { display: flex; flex-direction: column; gap: 16px; }

  .bw-order-card { border: 1.5px solid var(--border); border-radius: 14px; overflow: hidden; transition: border-color .2s, box-shadow .2s; }
  .bw-order-card:hover { border-color: var(--pink); box-shadow: 0 4px 18px rgba(232,80,138,.10); }

  .bw-order-card__header {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 10px; padding: 14px 18px;
    background: var(--pink-light);
    border-bottom: 1px solid rgba(232,80,138,.15);
  }
  .bw-order-card__meta { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .bw-order-card__name { font-weight: 700; color: var(--pink); font-size: .875rem; text-decoration: none; }
  .bw-order-card__name:hover { text-decoration: underline; }
  .bw-order-card__date { font-size: .78rem; color: var(--mid); }
  .bw-order-card__total { font-size: .85rem; font-weight: 600; }
  .bw-order-card__actions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }

  .bw-badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: .7rem; font-weight: 600; letter-spacing: .3px; }
  .bw-badge--fulfilled   { background: #e8f8ef; color: #1a7a45; }
  .bw-badge--unfulfilled { background: #fff3e0; color: #b25a00; }
  .bw-badge--cancelled   { background: #fdecea; color: #c0392b; }

  /* Product rows inside order */
  .bw-order-card__products { display: flex; flex-direction: column; gap: 0; }

  .bw-order-product {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 18px;
    border-bottom: 1px solid var(--border);
  }
  .bw-order-product:last-child { border-bottom: none; }

  .bw-order-product__img {
    width: 52px; height: 52px; border-radius: 8px;
    object-fit: cover; background: #f5f5f5;
    border: 1px solid var(--border); flex-shrink: 0;
  }
  .bw-order-product__img--placeholder {
    width: 52px; height: 52px; border-radius: 8px;
    background: var(--pink-light); border: 1px solid rgba(232,80,138,.2);
    display: flex; align-items: center; justify-content: center;
    color: var(--pink); font-size: 1.2rem; flex-shrink: 0;
  }
  .bw-order-product__info { flex: 1; min-width: 0; }
  .bw-order-product__title { font-size: .82rem; font-weight: 600; line-height: 1.3; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .bw-order-product__variant { font-size: .72rem; color: var(--mid); margin-top: 1px; }
  .bw-order-product__meta { display: flex; align-items: center; gap: 10px; margin-top: 4px; flex-wrap: wrap; }
  .bw-order-product__qty { font-size: .72rem; color: var(--mid); }
  .bw-order-product__price { font-size: .78rem; font-weight: 600; color: var(--pink); }

  /* "Write a Review" link per product */
  .bw-review-link {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: .7rem; font-weight: 600; color: var(--mid);
    text-decoration: none; padding: 3px 8px;
    border: 1px solid var(--border); border-radius: 20px;
    transition: border-color .18s, color .18s, background .18s;
    white-space: nowrap;
    margin-left: auto; flex-shrink: 0;
  }
  .bw-review-link:hover { border-color: var(--pink); color: var(--pink); background: var(--pink-light); }
  .bw-review-link svg { flex-shrink: 0; }

  /* ── SUBSCRIPTIONS – PayWhirl ── */
  .bw-pw-wrap {
    position: relative; border-radius: 12px; overflow: hidden;
    border: 1.5px solid var(--border); min-height: 520px;
  }
  .bw-pw-wrap iframe { display: block; width: 100%; min-height: 520px; border: none; }
  .bw-pw-loading {
    position: absolute; inset: 0; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 12px;
    color: var(--mid); font-size: .875rem; background: var(--white);
    pointer-events: none; transition: opacity .3s;
  }
  .bw-pw-loading__spinner {
    width: 36px; height: 36px; border: 3px solid var(--pink-light);
    border-top-color: var(--pink); border-radius: 50%;
    animation: bwSpin .8s linear infinite;
  }
  @keyframes bwSpin { to { transform: rotate(360deg); } }

  /* ── REWARDS ── */
  .bw-rewards-hero { background: linear-gradient(135deg, #e272a3 0%, #e272a3 100%); border-radius: 14px; padding: 28px; color: var(--white); margin-bottom: 22px; display: flex; align-items: center; gap: 18px; }
  .bw-rewards-hero__icon { font-size: 2.4rem; flex-shrink: 0; }
  .bw-rewards-hero__text h3 { font-family: 'Nunito', sans-serif; font-size: 1.2rem; margin-bottom: 5px; }
  .bw-rewards-hero__text p { font-size: .83rem; opacity: .9; line-height: 1.5; }
  .bw-lootly-cta { text-align: center; padding: 8px 0 4px; }
  .bw-lootly-btn { display: inline-flex; align-items: center; gap: 8px; background: var(--pink); color: var(--white); border: none; border-radius: 30px; padding: 13px 32px; font-size: .9rem; font-weight: 600; font-family: inherit; cursor: pointer; box-shadow: 0 4px 16px rgba(232,80,138,.30); transition: background .18s, transform .15s, box-shadow .18s; text-decoration: none; }
  .bw-lootly-btn:hover { background: var(--pink-hover); transform: translateY(-1px); box-shadow: 0 6px 22px rgba(232,80,138,.40); color: var(--white);}
  .bw-rewards-note { font-size: .78rem; color: var(--mid); margin-top: 10px; font-style: italic; }

  /* ── PROFILE ── */
  .bw-profile-form { max-width: 440px; }
  .bw-form-group { margin-bottom: 18px; }
  .bw-form-group label { display: block; font-size: .78rem; font-weight: 600; color: var(--mid); text-transform: uppercase; letter-spacing: .6px; margin-bottom: 6px; }
  .bw-form-group input { width: 100%; padding: 10px 13px; border: 1.5px solid var(--border); border-radius: 10px; font-family: inherit; font-size: .88rem; transition: border-color .18s, box-shadow .18s; outline: none; background: var(--white); }
  .bw-form-group input:focus { border-color: var(--pink); box-shadow: 0 0 0 3px rgba(232,80,138,.12); }
  .bw-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

  /* ── ADDRESSES ── */
  .bw-address-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 14px; margin-bottom: 18px; }
  .bw-address-card { border: 1.5px solid var(--border); border-radius: 12px; padding: 16px; font-size: .85rem; line-height: 1.6; position: relative; }
  .bw-address-card--default { border-color: var(--pink); background: var(--pink-light); }
  .bw-address-card__tag { position: absolute; top: 10px; right: 10px; background: var(--pink); color: var(--white); font-size: .62rem; font-weight: 700; padding: 2px 8px; border-radius: 20px; letter-spacing: .4px; text-transform: uppercase; }
  .bw-address-card__actions { margin-top: 10px; display: flex; gap: 10px; }
  .bw-text-link { font-size: .78rem; color: var(--pink); font-weight: 600; cursor: pointer; border: none; background: none; padding: 0; text-decoration: underline; font-family: inherit; }

  /* ── SHARED BUTTONS ── */
  .bw-btn { display: inline-flex; align-items: center; gap: 8px; padding: 11px 26px; border-radius: 30px; font-family: inherit; font-size: .85rem; font-weight: 600; cursor: pointer; border: none; transition: background .18s, transform .15s, box-shadow .18s; text-decoration: none; }
  .bw-btn--pink { background: var(--pink); color: var(--white); box-shadow: 0 4px 16px rgba(232,80,138,.28); }
  .bw-btn--pink:hover { background: var(--pink-hover); transform: translateY(-1px); box-shadow: 0 6px 22px rgba(232,80,138,.38); }
  .bw-btn--outline { background: transparent; color: var(--pink); border: 1.5px solid var(--pink); }
  .bw-btn--outline:hover { background: var(--pink-light); }
  .bw-btn--sm { padding: 7px 16px; font-size: .78rem; }

  /* ── SUPPRESS PAYWHIRL INJECTED LINK ── */
  .bw-account__sidebar [id*="paywhirl"],
  .bw-account__sidebar [class*="paywhirl"],
  .bw-account__sidebar a[href*="pw-page"],
  .bw-account__sidebar a[href*="paywhirl"] { display: none !important; }

  /* ══════════════════════════════════════
     RESPONSIVE — MOBILE
  ══════════════════════════════════════ */

  /* Tablet: shrink sidebar */
  @media (max-width: 900px) {
    .bw-account__layout { grid-template-columns: 200px 1fr; gap: 16px; }
    .bw-account__main { padding: 24px 22px; }
    .bw-brand__email { max-width: 110px; }
  }

  /* Mobile: hide sidebar, show bottom tab bar, full-width main */
  @media (max-width: 680px) {
    .bw-account { margin: 16px auto 90px; padding: 0 12px; }
    .bw-account__layout { grid-template-columns: 1fr; }
    .bw-account__sidebar { display: none; }
    .bw-mobile-nav { display: block; }
    .bw-account__main { padding: 20px 16px; min-height: auto; border-radius: 12px; }

    .bw-account__heading { font-size: 1.4rem; margin-bottom: 14px; }

    /* Welcome banner */
    .bw-welcome { padding: 14px 16px; gap: 12px; }
    .bw-welcome__avatar { width: 40px; height: 40px; font-size: .88rem; }

    /* Home grid: 2 cols on mobile */
    .bw-home-grid { grid-template-columns: 1fr 1fr; gap: 10px; }
    .bw-summary-card { padding: 14px; }
    .bw-summary-card__icon { width: 32px; height: 32px; margin-bottom: 10px; }
    .bw-summary-card__label { font-size: .85rem; }
    .bw-summary-card__desc { font-size: .7rem; }

    /* Order cards */
    .bw-order-card__header { padding: 12px 14px; }
    .bw-order-card__meta { gap: 8px; }
    .bw-order-card__actions { width: 100%; }
    .bw-order-card__actions .bw-btn { flex: 1; justify-content: center; }
    .bw-order-product { padding: 10px 14px; gap: 10px; }
    .bw-order-product__img, .bw-order-product__img--placeholder { width: 44px; height: 44px; }
    .bw-review-link { margin-left: 0; margin-top: 4px; }
    .bw-order-product__meta { flex-direction: column; align-items: flex-start; gap: 4px; }

    /* Profile form: single column on mobile */
    .bw-form-row { grid-template-columns: 1fr; gap: 0; }

    /* Rewards hero: stack on mobile */
    .bw-rewards-hero { flex-direction: column; text-align: center; padding: 22px 18px; gap: 12px; }

    /* Addresses: single column */
    .bw-address-grid { grid-template-columns: 1fr; }

    /* PayWhirl iframe */
    .bw-pw-wrap { min-height: 400px; }
    .bw-pw-wrap iframe { min-height: 400px; }

    /* Panel title */
    .bw-panel__title { font-size: 1.2rem; }
  }

  /* Very small phones */
  @media (max-width: 380px) {
    .bw-home-grid { grid-template-columns: 1fr; }
    .bw-mobile-nav__btn { padding: 8px 10px 10px; min-width: 52px; font-size: .58rem; }
  }

  .wtext{
  color: var(--white) !important;}
</style>

<!-- LOOTLY: Customer identification div -->
<div id="lootly-widget" class="lootly-init" style="display:none"
     data-provider="https://lootly.io"
     data-api-key="{{ lootly_api_key }}"
     data-shop-domain="{{ lootly_shop_domain }}"
     data-shop-id="{{ lootly_shop_id }}"
     data-customer-id="{{ customer.id }}"
     data-customer-email="{{ customer.email }}">
</div>

<div class="bw-account">

  <!-- PayWhirl sidebar link suppressor -->
  <script>
    document.addEventListener('DOMContentLoaded', function(){
      var sidebar = document.querySelector('.bw-account__sidebar');
      if (!sidebar) return;
      sidebar.querySelectorAll('a[href*="pw-page"], a[href*="paywhirl"], [id*="paywhirl"], [class*="paywhirl"]').forEach(function(el){
        el.parentNode && el.parentNode.removeChild(el);
      });
      if (window.MutationObserver) {
        new MutationObserver(function(mutations){
          mutations.forEach(function(m){
            m.addedNodes.forEach(function(node){
              if (node.nodeType === 1) {
                var href = (node.getAttribute && node.getAttribute('href')) || '';
                if (href.indexOf('pw-page') !== -1 || href.indexOf('paywhirl') !== -1 ||
                    (node.id && node.id.indexOf('paywhirl') !== -1) ||
                    (node.className && typeof node.className === 'string' && node.className.indexOf('paywhirl') !== -1)) {
                  node.parentNode && node.parentNode.removeChild(node);
                }
              }
            });
          });
        }).observe(sidebar, { childList: true, subtree: true });
      }
    });
  </script>

  <h1 class="bw-account__heading"><em>My</em> Account</h1>

  <div class="bw-account__layout">

    <!-- ══ DESKTOP SIDEBAR ══ -->
    <aside class="bw-account__sidebar">
      <div class="bw-brand">

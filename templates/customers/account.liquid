          {{ customer.first_name | slice: 0 | upcase }}{{ customer.last_name | slice: 0 | upcase }}
        </div>
        <div>
          <div class="bw-brand__name">Bombshell Wax</div>
          <div class="bw-brand__email">{{ customer.email }}</div>
        </div>
      </div>

      <ul class="bw-nav" data-pw-exclude="true">
        <li class="bw-nav__item">
          <a class="bw-nav__link" data-tab="home" href="#home">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Home
          </a>
        </li>
        <li class="bw-nav__item">
          <a class="bw-nav__link" data-tab="profile" href="#profile">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <em style="font-style:italic;font-family:'Nunito',sans-serif">My</em>&nbsp;profile
          </a>
        </li>
        <li class="bw-nav__item">
          <a class="bw-nav__link" data-tab="orders" href="#orders">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
            <em style="font-style:italic;font-family:'Nunito',sans-serif">My</em>&nbsp;orders
          </a>
        </li>
        <li class="bw-nav__item">
          <a class="bw-nav__link" data-tab="subscriptions" href="#subscriptions">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            <em style="font-style:italic;font-family:'Nunito',sans-serif">My</em>&nbsp;subscriptions

{% comment %}
  ══════════════════════════════════════════════════════════════════
  SHOPPER APPROVED SCROLL TRIGGER — add this to your product page
  template (e.g. sections/main-product.liquid), NOT here.

  The "Review" links in orders navigate to:
    {{ product.url }}#open-reviews

  On the product page, this snippet detects that hash and calls
  your existing scrollToTabsAndShow() function automatically,
  exactly as if the customer had clicked an .open-reviews link.

  <script>
    if (location.hash === '#open-reviews') {
      var reviewTabPoll = setInterval(function() {
        var tabLink = document.querySelector('a[data-toggle="tab"][href="#review"]');
        if (tabLink) {
          clearInterval(reviewTabPoll);
          scrollToTabsAndShow('a[data-toggle="tab"][href="#review"]');
        }
      }, 300);
      setTimeout(function(){ clearInterval(reviewTabPoll); }, 10000);
    }
  </script>
  ══════════════════════════════════════════════════════════════════
{% endcomment %}

<script>
(function () {
  var navLinks    = document.querySelectorAll('.bw-nav__link[data-tab]');
  var mobilebtns  = document.querySelectorAll('.bw-mobile-nav__btn[data-tab]');
  var panels      = document.querySelectorAll('.bw-panel[data-panel]');
  var cards       = document.querySelectorAll('.bw-summary-card[data-tab-link]');
  var pwLoaded    = false;

  function activate(tabName) {
    navLinks.forEach(function(l)   { l.classList.toggle('is-active', l.dataset.tab === tabName); });
    mobilebtns.forEach(function(b) { b.classList.toggle('is-active', b.dataset.tab === tabName); });
    panels.forEach(function(p)     { p.classList.toggle('is-active', p.dataset.panel === tabName); });

    if (tabName === 'subscriptions' && !pwLoaded) {
      pwLoaded = true;
      initPaywhirlIframe();
    }

    // Scroll to top of main panel on mobile after tab switch
    if (window.innerWidth <= 680) {
      var main = document.querySelector('.bw-account__main');
      if (main) main.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  function initPaywhirlIframe() {
    var iframe  = document.getElementById('paywhirl-customer-portal-frame');
    var loading = document.getElementById('pw-loading');
    if (!iframe) return;
    function hideLoading() {
      if (loading) { loading.style.opacity = '0'; setTimeout(function(){ loading.style.display = 'none'; }, 300); }
    }
    iframe.addEventListener('load', function () {
      hideLoading();
      try {
        var iframeDoc = iframe.contentDocument || iframe.contentWindow.document;
        var attempts = 0;
        var poll = setInterval(function () {
          attempts++;
          try {
            var doc = iframe.contentDocument || iframe.contentWindow.document;
            var header = doc.querySelector('.my-account-header, [class*="accountHeader"], [class*="account-header"]');
            if (header) header.style.display = 'none';
            var h = doc.body ? doc.body.scrollHeight : 0;
            if (h > 300) iframe.style.minHeight = (h + 20) + 'px';
            if (attempts > 30 || (header && h > 300)) clearInterval(poll);
          } catch(e) { clearInterval(poll); }
        }, 500);
        var initH = iframeDoc.body ? iframeDoc.body.scrollHeight : 0;
        if (initH > 300) iframe.style.minHeight = (initH + 20) + 'px';
      } catch(e) {
        iframe.style.minHeight = '680px';
      }
    });
    setTimeout(hideLoading, 8000);
    window.addEventListener('message', function(e) {
      if (e.data && typeof e.data === 'object' && e.data.type === 'paywhirl:resize' && e.data.height) {
        iframe.style.minHeight = (e.data.height + 20) + 'px';
      }
    });
  }

  function getTab() {
    if (location.search && location.search.indexOf('pw-page') !== -1) return 'subscriptions';
    return (location.hash || '').replace('#', '') || 'home';
  }

  function bindTab(el, tabKey) {
    el.addEventListener('click', function(e) {
      e.preventDefault();
      history.pushState(null, '', '#' + tabKey);
      activate(tabKey);
    });
  }

  navLinks.forEach(function(l)  { bindTab(l, l.dataset.tab); });
  mobilebtns.forEach(function(b){ bindTab(b, b.dataset.tab); });
  cards.forEach(function(c)     { bindTab(c, c.dataset.tabLink); });

  window.addEventListener('popstate', function(){ activate(getTab()); });
  activate(getTab());
})();
</script>

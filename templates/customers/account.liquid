            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Log out
          </a>
        </li>
      </ul>
    </aside>

    <!-- ══ MAIN CONTENT ══ -->
    <main class="bw-account__main">

      <!-- ── HOME ── -->
      <section class="bw-panel" id="tab-home" data-panel="home">
        <div class="bw-welcome">
          <div class="bw-welcome__avatar">
            {{ customer.first_name | slice: 0 | upcase }}{{ customer.last_name | slice: 0 | upcase }}
          </div>
          <div class="bw-welcome__text">
            <h2>Welcome back, {{ customer.first_name }}! ✨</h2>
            <p>Here's a quick look at everything in your account.</p>
          </div>
        </div>
        <div class="bw-home-grid">
          <a class="bw-summary-card" data-tab-link="profile" href="#profile">
            <div class="bw-summary-card__icon"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
            <div class="bw-summary-card__label">My profile</div>
            <div class="bw-summary-card__desc">Update your name, email, and password anytime.</div>
          </a>
          <a class="bw-summary-card" data-tab-link="orders" href="#orders">
            <div class="bw-summary-card__icon"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg></div>
            <div class="bw-summary-card__label">My orders</div>
            <div class="bw-summary-card__desc">{% if customer.orders_count > 0 %}{{ customer.orders_count }} order(s) placed. Track &amp; reorder here.{% else %}No orders yet — browse the shop!{% endif %}</div>
          </a>
          <a class="bw-summary-card" data-tab-link="subscriptions" href="#subscriptions">
            <div class="bw-summary-card__icon"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></div>
            <div class="bw-summary-card__label">My subscriptions</div>
            <div class="bw-summary-card__desc">Manage, pause, or cancel your active subscriptions.</div>
          </a>
          <a class="bw-summary-card" data-tab-link="rewards" href="#rewards">
            <div class="bw-summary-card__icon"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
            <div class="bw-summary-card__label">My rewards</div>
            <div class="bw-summary-card__desc">Check your Lootly points and redeem rewards.</div>
          </a>
          <a class="bw-summary-card" data-tab-link="addresses" href="#addresses">
            <div class="bw-summary-card__icon"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
            <div class="bw-summary-card__label">My addresses</div>
            <div class="bw-summary-card__desc">{% assign addr_count = customer.addresses | size %}{% if addr_count > 0 %}{{ addr_count }} saved address(s). Edit or add more.{% else %}Save a shipping address for faster checkout.{% endif %}</div>
          </a>
        </div>
      </section>

      <!-- ── PROFILE ── -->
      <section class="bw-panel" id="tab-profile" data-panel="profile">
        <h2 class="bw-panel__title"><em>My</em> profile</h2>
        <hr class="bw-panel__rule">
        {% form 'customer' %}
          {{ form.errors | default_errors }}
          <div class="bw-profile-form">
            <div class="bw-form-row">
              <div class="bw-form-group">
                <label for="FirstName">First name</label>
                <input type="text" id="FirstName" name="customer[first_name]" value="{{ customer.first_name }}" autocomplete="given-name">
              </div>
              <div class="bw-form-group">
                <label for="LastName">Last name</label>
                <input type="text" id="LastName" name="customer[last_name]" value="{{ customer.last_name }}" autocomplete="family-name">
              </div>
            </div>
            <div class="bw-form-group">
              <label for="Email">Email address</label>
              <input type="email" id="Email" name="customer[email]" value="{{ customer.email }}" autocomplete="email">
            </div>
            <div class="bw-form-group">
              <label for="Phone">Phone number</label>
              <input type="tel" id="Phone" name="customer[phone]" value="{{ customer.phone }}" autocomplete="tel">
            </div>
            <div class="bw-form-group">
              <label for="Password">New password <span style="font-weight:300;text-transform:none">(leave blank to keep current)</span></label>
              <input type="password" id="Password" name="customer[password]" autocomplete="new-password">
            </div>
            <div class="bw-form-group">
              <label for="PasswordConfirm">Confirm new password</label>
              <input type="password" id="PasswordConfirm" name="customer[password_confirmation]" autocomplete="new-password">
            </div>
            <button type="submit" class="bw-btn bw-btn--pink">Save changes</button>
          </div>
        {% endform %}
      </section>

      <!-- ── ORDERS ── -->
      <section class="bw-panel" id="tab-orders" data-panel="orders">
        <h2 class="bw-panel__title"><em>My</em> orders</h2>
        <hr class="bw-panel__rule">

        {% if customer.orders.size == 0 %}
          <div class="bw-orders-empty">
            <div class="bw-orders-empty__icon">🛍️</div>
            <p>You haven't placed any orders yet.</p>
            <a href="{{ routes.collections_url }}/all" class="bw-btn bw-btn--pink" style="margin-top:16px">Start shopping</a>
          </div>
        {% else %}
          <div class="bw-order-list">
            {% for order in customer.orders %}

              {% assign reorder_items = '' %}
              {% for line_item in order.line_items %}
                {% assign item_part = line_item.variant_id | append: ':' | append: line_item.quantity %}
                {% if forloop.first %}
                  {% assign reorder_items = item_part %}
                {% else %}
                  {% assign reorder_items = reorder_items | append: ',' | append: item_part %}
                {% endif %}
              {% endfor %}
              {% assign reorder_url = '/cart/' | append: reorder_items %}

              <div class="bw-order-card">

                <div class="bw-order-card__header">
                  <div class="bw-order-card__meta">
                    <a href="{{ order.customer_url }}" class="bw-order-card__name">{{ order.name }}</a>
                    <span class="bw-order-card__date">{{ order.created_at | date: '%b %d, %Y' }}</span>
                    {% if order.fulfillment_status == 'fulfilled' %}
                      <span class="bw-badge bw-badge--fulfilled">Fulfilled</span>
                    {% elsif order.cancelled_at %}
                      <span class="bw-badge bw-badge--cancelled">Cancelled</span>
                    {% else %}
                      <span class="bw-badge bw-badge--unfulfilled">Processing</span>
                    {% endif %}
                    <span class="bw-order-card__total">{{ order.total_price | money }}</span>
                  </div>
                  <div class="bw-order-card__actions">
                    <a href="{{ order.customer_url }}" class="bw-btn bw-btn--outline bw-btn--sm">View details</a>
                    {% unless order.cancelled_at %}
                      <a href="{{ reorder_url }}" class="bw-btn bw-btn--pink bw-btn--sm wtext">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
                        Reorder
                      </a>
                    {% endunless %}
                  </div>
                </div>

                <div class="bw-order-card__products">
                  {% for line_item in order.line_items %}
                    <div class="bw-order-product">

                      {% if line_item.image %}
                        <img class="bw-order-product__img"
                             src="{{ line_item.image | img_url: '120x120', crop: 'center' }}"
                             alt="{{ line_item.title | escape }}"
                             loading="lazy" width="52" height="52">
                      {% else %}
                        <div class="bw-order-product__img--placeholder">🧴</div>
                      {% endif %}

                      <div class="bw-order-product__info">
                        <div class="bw-order-product__title">{{ line_item.title }}</div>
                        {% unless line_item.variant_title == 'Default Title' or line_item.variant_title == blank %}
                          <div class="bw-order-product__variant">{{ line_item.variant_title }}</div>
                        {% endunless %}
                        <div class="bw-order-product__meta">
                          <span class="bw-order-product__qty">Qty: {{ line_item.quantity }}</span>
                          <span class="bw-order-product__price">{{ line_item.final_price | money }}</span>
                        </div>
                      </div>

                      {% comment %}
                        Review link — only shown for non-cancelled orders.
                        Uses class="open-reviews" which your product page already
                        listens for via scrollToTabsAndShow('a[data-toggle="tab"][href="#review"]').
                        The link navigates to the product page; on arrival the
                        open-reviews click handler fires automatically via the
                        hash check (see comment block near bottom of this file).
                      {% endcomment %}
                      {% unless order.cancelled_at %}
                        {% if line_item.product.url != blank %}
                          <a class="bw-review-link open-reviews"
                             href="{{ line_item.product.url }}#open-reviews"
                             target="_blank" rel="noopener"
                             title="Write a review for {{ line_item.title | escape }}">

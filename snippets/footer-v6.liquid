{% if section.settings.select_fts == "footer_v6" %}
{% if template contains 'index' %}
<footer class="footer_v6" style="background-color : {{section.settings.ft_home_bg_footer}}">
  <div class="content_menu">
    <div class="container container-v1">    
      <div class="row align-items-center">
        <div class="col-lg-4 text-center {% if settings.enable_rtl_mode %} text-lg-right {% else %} text-lg-left {% endif %} ">
          <div class="menu">
            <ul class="list-inline list-unstyled mb-0">
              {% for link in linklists[settings.menu_fv6].links %}
              <li class="list-inline-item mr-0"><a href="{{link.url}}" title="{{link.title}}">{{link.title}}</a></li>
              {% endfor %}
            </ul>
          </div>
        </div>
        <div class="col-lg-4 text-center justify-center">
          <div class="logo-footer">
            {% if settings.logo_svg6 !=blank %}
            <div class="logosvg" style="max-width:{{settings.fv6_main_logo_maxwidth}}px;">
              <a class="d-block" href="{{shop.url}}">{{settings.logo_svg6}}</a>
            </div>          
            {% else %}            
            <a href="{{shop.url}}" class="logo">
              {% if settings.fv6_main_logo != blank %}
              <img src="{{settings.fv6_main_logo | img_url:'master'}}"  width="{{settings.fv6_main_logo_maxwidth}}" alt="{{shop.name}}" class="img-fluid">
              {% else %}
              <img src="//via.placeholder.com/120x35" width="{{settings.fv6_main_logo_maxwidth}}" alt="{{shop.name}}" class="img-fluid">
              {% endif %}
            </a>
            {% endif %}
          </div>
        </div>
        <div class="col-lg-4 {% if settings.enable_rtl_mode %} text-lg-left {% else %} text-lg-right {% endif %} text-center">
          <div class="klaviyo-form-Um8xNf"></div>
          <div class="casano-socials">
            <ul class="list-inline list-unstyled mb-0">
              {% if settings.icon_sc_fv6_1 !=blank %}
              <li class="list-inline-item mr-0 mb-0">
                <a href="{{settings.url_sc_fv6_1}}" title="" target="_blank" class="social-item"><i class="{{settings.icon_sc_fv6_1}}"></i></a>
              </li>
              {% endif %}
              {% if settings.icon_sc_fv6_2 !=blank %}
              <li class="list-inline-item mr-0 mb-0">
                <a href="{{settings.url_sc_fv6_2}}" title="" target="_blank" class="social-item"><i class="{{settings.icon_sc_fv6_2}}"></i></a>
              </li>
              {% endif %}
              {% if settings.icon_sc_fv6_3 !=blank %}
              <li class="list-inline-item mr-0 mb-0">
                <a href="{{settings.url_sc_fv6_3}}" title="" target="_blank" class="social-item"><i class="{{settings.icon_sc_fv6_3}}"></i></a>
              </li>
              {% endif %}
              {% if settings.icon_sc_fv6_4 !=blank %}
              <li class="list-inline-item mr-0 mb-0">
                <a href="{{settings.url_sc_fv6_4}}" title="" target="_blank" class="social-item"><i class="{{settings.icon_sc_fv6_4}}"></i></a>
              </li>
              {% endif %}  
              {% if settings.icon_sc_fv6_5 !=blank %}
              <li class="list-inline-item mr-0 mb-0">
                <a href="{{settings.url_sc_fv6_5}}" title="" target="_blank" class="social-item"><i class="{{settings.icon_sc_fv6_5}}"></i></a>
              </li>
              {% endif %}
            </ul>

           <!-- shopper approved snippets/footer-v6.liquid --> 
            
<a href="https://www.shopperapproved.com/reviews/bombshellwax.com" class="shopperlink new-sa-seals placement-393" style="margin-top:10px;"> <img src="//www.shopperapproved.com/svg-seal/35487/393-sa-seal.svg" style="border-radius: 4px;" alt="Customer Reviews" oncontextmenu="alert('Copying Prohibited by Law - This image and all included logos are copyrighted by Shopper Approved.'); return false;" /> </a> <script type="text/javascript"> (function() { var js = document.createElement("script"); js.innerHTML = `function openshopperapproved(e) { var isIE = navigator.appName === "Microsoft Internet Explorer"; var windowHeight = screen.availHeight - 90; var windowWidth = window.innerWidth < 1400 ? 620 : 940; window.open(this.href, "shopperapproved", "location=" + (isIE ? "yes" : "no") + ",scrollbars=yes,width=" + windowWidth + ",height=" + windowHeight + ",menubar=no,toolbar=no"); e.stopPropagation?.(); return false; } document.querySelectorAll(".shopperlink").forEach(link => link.onclick = openshopperapproved);`; js.type = "text/javascript"; document.head.appendChild(js); var link = document.createElement('link'); link.rel = 'stylesheet'; link.type = 'text/css'; link.href = "//www.shopperapproved.com/svg-seal/393.css"; document.head.appendChild(link); })(); </script>

      <!-- end shopper approved snippets/footer-v6.liquid -->
          </div>
        </div> 
      </div>
    </div> 
  </div>
  <div class="copyright text-center">
    {% if settings.copyright_fv6 != blank %}
    {{settings.copyright_fv6}}
    {% else %}
    <div class="text-copyright mb-0"><p>© Copyright 2022 | <a href="http://engotheme.com/" rel="nofollow" target="_blank" class="underline_hover bold"> SoapicStore </a> By <a href="http://engotheme.com/" rel="nofollow" target="_blank" class="underline_hover link"> Engoheme.</a><a href="https://www.shopify.com/?ref=shopifycenter" rel="nofollow" target="_blank" class=""> Powered by Shopify.</a></p> 
    </div> 
    {% endif %}
  </div>
</footer>

<style>
  .footer_v6 .copyright{
    color : {{section.settings.ft_home_color_text}};
  }
  .footer_v6 .content_menu .menu ul li a{
    color : {{section.settings.ft_home_color_text}};
  }
  .footer_v6 .content_menu .casano-socials ul li a{
    border-color : {{section.settings.ft_home_color_text}};
    color : {{section.settings.ft_home_color_text}};
  }
  .klaviyo-form-Um8xNf{
  padding-bottom: 15px;}
</style>
{% endif %}
{% endif %}


/* Ingredient List dropdown */
  .dropdown-section {
    border: 1px solid #ddd;
    border-radius: 8px;
    margin: 10px 0;
    overflow: hidden;
  }

  .dropdown-header {
    background-color: #f8f8f8;
    cursor: pointer;

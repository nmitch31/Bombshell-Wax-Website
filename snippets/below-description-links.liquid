<script>
  document.addEventListener("DOMContentLoaded", function() {
    function scrollToTabsAndShow(tabSelector) {
      const tabSection = document.getElementById("tab-section");
      if (tabSection) {
        const yOffset = -300; // adjust for sticky header/extra space
        const y = tabSection.getBoundingClientRect().top + window.pageYOffset + yOffset;
        window.scrollTo({ top: y, behavior: "smooth" });

        // After scrolling, activate tab via Bootstrap
        setTimeout(() => {
          const tabButton = document.querySelector(tabSelector);
          if (tabButton && typeof jQuery !== "undefined") {
            jQuery(tabButton).tab("show");
          }
        }, 600);
      }
    }

    // Click handler: How to Use
    document.querySelectorAll(".open-how-to-use").forEach(link => {
      link.addEventListener("click", function(e) {
        e.preventDefault();
        scrollToTabsAndShow('a[data-toggle="tab"][href="#add"]');
      });
    });

    // Click handler: Performance
     document.querySelectorAll(".open-performance").forEach(link => {
      link.addEventListener("click", function(e) {
        e.preventDefault();
        scrollToTabsAndShow('a[data-toggle="tab"][href="#perf"]');
      });
    });

    // Click handler: Reviews
    document.querySelectorAll(".open-reviews").forEach(link => {
      link.addEventListener("click", function(e) {
        e.preventDefault();
        scrollToTabsAndShow('a[data-toggle="tab"][href="#review"]');
      });
    });

    // New — handles arriving from the account page order history via #open-reviews hash
if (location.hash === '#open-reviews') {
  var reviewTabPoll = setInterval(function() {
    var tabLink = document.querySelector('a[data-toggle="tab"][href="#review"]');
    if (tabLink) {
      clearInterval(reviewTabPoll);
      scrollToTabsAndShow('a[data-toggle="tab"][href="#review"]');
    }
  }, 300);
  setTimeout(function(){ clearInterval(reviewTabPoll); }, 10000);
}

    // On page load: if URL has "#reviews", override the browser jump
    if (window.location.hash === "#reviews") {
      // Reset scroll to top first to cancel the browser's default behavior
      window.scrollTo(0, 0);

      // Then trigger your custom scroll + tab activation
      setTimeout(() => {
        scrollToTabsAndShow('a[data-toggle="tab"][href="#review"]');
      }, 100);
    }
  });
</script>

<script>
  document.querySelectorAll('.dropdown-header').forEach(header => {
    header.addEventListener('click', () => {
      const section = header.parentElement;
      section.classList.toggle('active');
    });
  });
</script>
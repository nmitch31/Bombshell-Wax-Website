{% schema %}
{
  "name": "Social Media Icons",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Follow Us"
    },
    {
      "type": "range",
      "id": "icon_size_desktop",
      "label": "Icon Size (Desktop)",
      "min": 20,
      "max": 120,
      "step": 2,
      "default": 40
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "label": "Icon Size (Mobile)",
      "min": 20,
      "max": 120,
      "step": 2,
      "default": 32
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Spacing Between Icons",
      "min": 5,
      "max": 50,
      "step": 1,
      "default": 20
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "icon",
      "name": "Social Icon",
      "settings": [
        {
          "type": "textarea",
          "id": "svg_icon",
          "label": "SVG Icon Code",
          "default": "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='currentColor' d='M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z'/></svg>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Social Link"
        },
        {
          "type": "checkbox",
          "id": "open_in_new_tab",
          "label": "Open in new tab?",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Media Icons",
      "blocks": [
        { "type": "icon" },
        { "type": "icon" },
        { "type": "icon" }
      ]
    }
  ]
}
{% endschema %}

<style>
  .social-icons-section {
    text-align: center;
    padding: 40px 0;
  }

  .social-icons-title {
    margin-bottom: 20px;
  }

  .social-icons-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ section.settings.icon_spacing }}px;
    flex-wrap: wrap;
  }

  .social-icons-wrapper a svg {
    width: {{ section.settings.icon_size_desktop }}px;
    height: {{ section.settings.icon_size_desktop }}px;
    fill: {{ section.settings.icon_color }};
    transition: transform 0.2s ease;
  }

  .social-icons-wrapper a:hover svg {
    transform: scale(1.1);
  }

  @media (max-width: 768px) {
    .social-icons-wrapper a svg {
      width: {{ section.settings.icon_size_mobile }}px;
      height: {{ section.settings.icon_size_mobile }}px;
    }
  }
</style>

<div class="social-icons-section">
  {% if section.settings.title != blank %}
    <h3 class="social-icons-title">{{ section.settings.title }}</h3>
  {% endif %}

  <div class="social-icons-wrapper">
    {% for block in section.blocks %}
      <a 
        href="{{ block.settings.link | default: '#' }}" 
        {% if block.settings.open_in_new_tab %}target="_blank"{% endif %}
      >
        {{ block.settings.svg_icon }}
      </a>
    {% endfor %}
  </div>
</div>

{% style %}
   .product-row-btn {
    display: inline-block;
    margin-top: 12px;
    padding: 10px 18px;
    background-color: #111;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    border-radius: 6px;
    text-decoration: none;
    transition: background-color 0.25s ease, transform 0.25s ease;
   }

   .product-row-btn:hover {
    background-color: #333;
    transform: translateY(-2px);
   }



  .two-col-product-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 0; /* vertical only */
    display: flex;
    gap: 50px; /* more spacing */
    overflow-x: hidden; /* prevents boxed theme scroll */
    box-sizing: border-box;
  }

  .two-col-product-column {
    flex: 0 0 50%;
    min-width: 0; /* CRITICAL: prevents overflow */
    padding: 0 10px;
  }

  /* Vertical divider */
  .two-col-product-column:first-child {
    border-right: 1px solid #d9d9d9;
    padding-right: 25px;
  }

  .two-col-product-column:last-child {
    padding-left: 25px;
  }

  @media screen and (max-width: 768px) {
    .two-col-product-section {
      flex-direction: column;
      gap: 40px;
    }

    .two-col-product-column:first-child {
      border-right: none;
      padding-right: 0;
    }

    .two-col-product-column:last-child {
      padding-left: 0;
    }
  }

  .product-row-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
  }

  .product-row-image-wrapper {
    flex-shrink: 0;
    max-width: 500px;
    max-height: 200px;
    overflow: hidden;
    border-radius: var(--image-radius);
  }

  .product-row-image {
    width: 100%;
    height: auto;
    max-width: 500px;
    max-height: 200px;
    object-fit: contain;
  }

  .product-row-title {
    margin: 0 0 8px 0;
    font-weight: 600;
  }

  .product-row-subheader {
    margin: 0;
    line-height: 1.5;
  }

  .product-row-products {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }

  .product-row-grid {
    display: flex;
    gap: var(--product-gap);
    padding-bottom: 16px;
  }

  .product-card {
    flex: 0 0 var(--product-width);
    background-color: var(--product-bg);
    border-radius: var(--product-radius);
    padding: var(--product-padding);
    border: 1px solid var(--product-border);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-sizing: border-box;
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .product-card-image {
    width: 100%;
    aspect-ratio: 1;
    margin-bottom: 12px;
    border-radius: var(--product-image-radius);
    overflow: hidden;
  }

  .product-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-card-title {
    margin: 0 0 8px 0;
    font-weight: 500;
    line-height: 1.3;
  }

  .product-card-price {
    font-weight: 600;
  }
{% endstyle %}

<div class="two-col-product-section">

  <!-- COLUMN 1 -->
  <div class="two-col-product-column" style="
    --image-radius: {{ section.settings.col1_image_radius }}px;
    --product-width: {{ section.settings.col1_product_width }}px;
    --product-gap: {{ section.settings.col1_product_gap }}px;
    --product-bg: {{ section.settings.col1_product_bg }};
    --product-border: {{ section.settings.col1_product_border }};
    --product-padding: {{ section.settings.col1_product_padding }}px;
    --product-radius: {{ section.settings.col1_product_radius }}px;
    --product-image-radius: {{ section.settings.col1_product_image_radius }}px;
  ">
    <div class="product-row-header">
      <div class="product-row-image-wrapper">
        {% if section.settings.col1_image %}
          <img
            src="{{ section.settings.col1_image | image_url: width: 500 }}"
            alt="{{ section.settings.col1_image.alt | escape }}"
            class="product-row-image"
            loading="lazy"
          >
        {% endif %}
      </div>

      <div>
        <h2 class="product-row-title" style="font-size: {{ section.settings.col1_title_size }}px; color: {{ section.settings.col1_title_color }};">
          {{ section.settings.col1_title }}
        </h2>
        <p class="product-row-subheader" style="font-size: {{ section.settings.col1_subheader_size }}px; color: {{ section.settings.col1_subheader_color }};">
          {{ section.settings.col1_subheader }}
        </p>
        {% if section.settings.col1_button_text != blank and section.settings.col1_button_link != blank %}
          <a href="{{ section.settings.col1_button_link }}" class="product-row-btn">
          {{ section.settings.col1_button_text }}
          </a>
        {% endif %}

      </div>
    </div>

    {% if section.settings.col1_collection != blank %}
      <div class="product-row-products">
        <div class="product-row-grid">
          {% for product in section.settings.col1_collection.products limit: section.settings.col1_limit %}
            <div class="product-card">
              <a href="{{ product.url }}">
                <div class="product-card-image">
                  {% if product.featured_image %}
                    <img src="{{ product.featured_image | image_url: width: 400 }}" loading="lazy">
                  {% endif %}
                </div>

                <h3 class="product-card-title" style="font-size: {{ section.settings.col1_product_title_size }}px; color: {{ section.settings.col1_product_title_color }};">
                  {{ product.title }}
                </h3>

                <div class="product-card-price" style="font-size: {{ section.settings.col1_product_price_size }}px; color: {{ section.settings.col1_product_price_color }};">
                  {{ product.price | money }}
                </div>
              </a>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>

  <!-- COLUMN 2 -->
  <div class="two-col-product-column" style="
    --image-radius: {{ section.settings.col2_image_radius }}px;
    --product-width: {{ section.settings.col2_product_width }}px;
    --product-gap: {{ section.settings.col2_product_gap }}px;
    --product-bg: {{ section.settings.col2_product_bg }};
    --product-border: {{ section.settings.col2_product_border }};
    --product-padding: {{ section.settings.col2_product_padding }}px;
    --product-radius: {{ section.settings.col2_product_radius }}px;
    --product-image-radius: {{ section.settings.col2_product_image_radius }}px;
  ">
    <div class="product-row-header">
      <div class="product-row-image-wrapper">
        {% if section.settings.col2_image %}
          <img
            src="{{ section.settings.col2_image | image_url: width: 500 }}"
            alt="{{ section.settings.col2_image.alt | escape }}"
            class="product-row-image"
            loading="lazy"
          >
        {% endif %}
      </div>

      <div>
        <h2 class="product-row-title" style="font-size: {{ section.settings.col2_title_size }}px; color: {{ section.settings.col2_title_color }};">
          {{ section.settings.col2_title }}
        </h2>
        <p class="product-row-subheader" style="font-size: {{ section.settings.col2_subheader_size }}px; color: {{ section.settings.col2_subheader_color }};">
          {{ section.settings.col2_subheader }}
        </p>
        {% if section.settings.col2_button_text != blank and section.settings.col2_button_link != blank %}
         <a href="{{ section.settings.col2_button_link }}" class="product-row-btn">
         {{ section.settings.col2_button_text }}
         </a>
        {% endif %}

      </div>
    </div>

    {% if section.settings.col2_collection != blank %}
      <div class="product-row-products">
        <div class="product-row-grid">
          {% for product in section.settings.col2_collection.products limit: section.settings.col2_limit %}
            <div class="product-card">
              <a href="{{ product.url }}">
                <div class="product-card-image">
                  {% if product.featured_image %}
                    <img src="{{ product.featured_image | image_url: width: 400 }}" loading="lazy">
                  {% endif %}
                </div>

                <h3 class="product-card-title" style="font-size: {{ section.settings.col2_product_title_size }}px; color: {{ section.settings.col2_product_title_color }};">
                  {{ product.title }}
                </h3>

                <div class="product-card-price" style="font-size: {{ section.settings.col2_product_price_size }}px; color: {{ section.settings.col2_product_price_color }};">
                  {{ product.price | money }}
                </div>
              </a>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>

</div>



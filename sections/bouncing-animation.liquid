{% comment %}
  Section: Bouncing Product Animation
  - Traveller (serum vial) bounces CENTRED over each base image
  - Desktop: 4 bases — 3 wax bags + wax warmer (cash target)
  - Mobile (<=600px): 3 bases — 2 wax bags + warmer. 4th bag hidden.
  - On warmer: vial shrinks + fades in, cash/coins/bills explode out
  - Auto-plays on loop when section is 25% in view
{% endcomment %}

<div id="{{ section.id }}" class="bounce-section" data-section-id="{{ section.id }}">

  <div class="bounce-stage" aria-hidden="true">

    <div class="bounce-bases">
      {% assign base_count = 0 %}
      {% for block in section.blocks %}
        {% if block.type == "base_image" and base_count < 4 %}
          {% assign base_num = base_count | plus: 1 %}
          <div class="bounce-base bounce-base--{{ base_num }}" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 400 }}"
                alt="{{ block.settings.image_alt | escape }}"
                width="400" height="auto" loading="lazy"
                class="bounce-base__img{% if base_num == 4 %} bounce-base__img--target{% endif %}"
              >
            {% else %}
              <div class="bounce-base__placeholder">
                {{ 'product-1' | placeholder_svg_tag: 'bounce-base__svg' }}
              </div>
            {% endif %}

            {% if base_num == 4 %}
              <div class="cash-explosion" id="{{ section.id }}-cash">
                <span class="cash-item cash-bill cash-bill--1" aria-hidden="true"><svg viewBox="0 0 56 32" xmlns="http://www.w3.org/2000/svg"><rect width="56" height="32" rx="4" fill="#4CAF50"/><rect x="4" y="4" width="48" height="24" rx="2" fill="#388E3C"/><circle cx="28" cy="16" r="7" fill="#4CAF50" stroke="#81C784" stroke-width="1.5"/><text x="28" y="20.5" text-anchor="middle" font-size="9" font-weight="bold" fill="#fff" font-family="sans-serif">$</text><rect x="2" y="13" width="7" height="6" rx="1" fill="#4CAF50" stroke="#81C784" stroke-width="1"/><rect x="47" y="13" width="7" height="6" rx="1" fill="#4CAF50" stroke="#81C784" stroke-width="1"/></svg></span>
                <span class="cash-item cash-bill cash-bill--2" aria-hidden="true"><svg viewBox="0 0 56 32" xmlns="http://www.w3.org/2000/svg"><rect width="56" height="32" rx="4" fill="#4CAF50"/><rect x="4" y="4" width="48" height="24" rx="2" fill="#388E3C"/><circle cx="28" cy="16" r="7" fill="#4CAF50" stroke="#81C784" stroke-width="1.5"/><text x="28" y="20.5" text-anchor="middle" font-size="9" font-weight="bold" fill="#fff" font-family="sans-serif">$</text><rect x="2" y="13" width="7" height="6" rx="1" fill="#4CAF50" stroke="#81C784" stroke-width="1"/><rect x="47" y="13" width="7" height="6" rx="1" fill="#4CAF50" stroke="#81C784" stroke-width="1"/></svg></span>
                <span class="cash-item cash-bill cash-bill--3" aria-hidden="true"><svg viewBox="0 0 56 32" xmlns="http://www.w3.org/2000/svg"><rect width="56" height="32" rx="4" fill="#66BB6A"/><rect x="4" y="4" width="48" height="24" rx="2" fill="#43A047"/><circle cx="28" cy="16" r="7" fill="#66BB6A" stroke="#A5D6A7" stroke-width="1.5"/><text x="28" y="20.5" text-anchor="middle" font-size="9" font-weight="bold" fill="#fff" font-family="sans-serif">$</text><rect x="2" y="13" width="7" height="6" rx="1" fill="#66BB6A" stroke="#A5D6A7" stroke-width="1"/><rect x="47" y="13" width="7" height="6" rx="1" fill="#66BB6A" stroke="#A5D6A7" stroke-width="1"/></svg></span>
                <span class="cash-item cash-bill cash-bill--4" aria-hidden="true"><svg viewBox="0 0 56 32" xmlns="http://www.w3.org/2000/svg"><rect width="56" height="32" rx="4" fill="#388E3C"/><rect x="4" y="4" width="48" height="24" rx="2" fill="#2E7D32"/><circle cx="28" cy="16" r="7" fill="#388E3C" stroke="#81C784" stroke-width="1.5"/><text x="28" y="20.5" text-anchor="middle" font-size="9" font-weight="bold" fill="#fff" font-family="sans-serif">$</text><rect x="2" y="13" width="7" height="6" rx="1" fill="#388E3C" stroke="#81C784" stroke-width="1"/><rect x="47" y="13" width="7" height="6" rx="1" fill="#388E3C" stroke="#81C784" stroke-width="1"/></svg></span>
                <span class="cash-item cash-bill cash-bill--5" aria-hidden="true"><svg viewBox="0 0 56 32" xmlns="http://www.w3.org/2000/svg"><rect width="56" height="32" rx="4" fill="#4CAF50"/><rect x="4" y="4" width="48" height="24" rx="2" fill="#388E3C"/><circle cx="28" cy="16" r="7" fill="#4CAF50" stroke="#81C784" stroke-width="1.5"/><text x="28" y="20.5" text-anchor="middle" font-size="9" font-weight="bold" fill="#fff" font-family="sans-serif">$</text><rect x="2" y="13" width="7" height="6" rx="1" fill="#4CAF50" stroke="#81C784" stroke-width="1"/><rect x="47" y="13" width="7" height="6" rx="1" fill="#4CAF50" stroke="#81C784" stroke-width="1"/></svg></span>
                <span class="cash-item cash-coin cash-coin--1" aria-hidden="true"><svg viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg"><circle cx="14" cy="14" r="13" fill="#FDD835" stroke="#F9A825" stroke-width="1.5"/><circle cx="14" cy="14" r="9" fill="#FFEE58" stroke="#F9A825" stroke-width="1"/><text x="14" y="18.5" text-anchor="middle" font-size="10" font-weight="bold" fill="#F57F17" font-family="sans-serif">$</text></svg></span>
                <span class="cash-item cash-coin cash-coin--2" aria-hidden="true"><svg viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg"><circle cx="14" cy="14" r="13" fill="#FDD835" stroke="#F9A825" stroke-width="1.5"/><circle cx="14" cy="14" r="9" fill="#FFEE58" stroke="#F9A825" stroke-width="1"/><text x="14" y="18.5" text-anchor="middle" font-size="10" font-weight="bold" fill="#F57F17" font-family="sans-serif">$</text></svg></span>
                <span class="cash-item cash-coin cash-coin--3" aria-hidden="true"><svg viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg"><circle cx="14" cy="14" r="13" fill="#FFB300" stroke="#FF8F00" stroke-width="1.5"/><circle cx="14" cy="14" r="9" fill="#FFC107" stroke="#FF8F00" stroke-width="1"/><text x="14" y="18.5" text-anchor="middle" font-size="10" font-weight="bold" fill="#E65100" font-family="sans-serif">$</text></svg></span>
                <span class="cash-item cash-coin cash-coin--4" aria-hidden="true"><svg viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg"><circle cx="14" cy="14" r="13" fill="#FDD835" stroke="#F9A825" stroke-width="1.5"/><circle cx="14" cy="14" r="9" fill="#FFEE58" stroke="#F9A825" stroke-width="1"/><text x="14" y="18.5" text-anchor="middle" font-size="10" font-weight="bold" fill="#F57F17" font-family="sans-serif">$</text></svg></span>
                <span class="cash-item cash-sign cash-sign--1" aria-hidden="true">💵</span>
                <span class="cash-item cash-sign cash-sign--2" aria-hidden="true">💰</span>
                <span class="cash-item cash-sign cash-sign--3" aria-hidden="true">💵</span>
              </div>
              <div class="warmer-glow"></div>
            {% endif %}
          </div>
          {% assign base_count = base_count | plus: 1 %}
        {% endif %}
      {% endfor %}
    </div>

    {%- comment -%} Bouncing traveller (serum vial) {%- endcomment -%}
    <div class="bounce-traveller" id="{{ section.id }}-traveller">
      {% assign traveller_block = null %}
      {% for block in section.blocks %}
        {% if block.type == "traveller_image" %}{% assign traveller_block = block %}{% endif %}
      {% endfor %}
      {% if traveller_block != null and traveller_block.settings.image != blank %}
        <img src="{{ traveller_block.settings.image | image_url: width: 400 }}" alt="{{ traveller_block.settings.image_alt | escape }}" width="400" height="auto" loading="lazy">
      {% else %}
        <div class="bounce-base__placeholder">{{ 'product-2' | placeholder_svg_tag: 'bounce-base__svg' }}</div>
      {% endif %}
    </div>

    {%- comment -%} ── Star trigger — lives inside stage so position:absolute works ── {%- endcomment -%}
    <div class="ng-star-wrap" id="{{ section.id }}-star">
      <button class="ng-star-btn" id="{{ section.id }}-star-btn" aria-label="Play a quick game">
        <svg class="ng-star-icon" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
          <polygon points="19,3 23.5,14 36,15 27,23.5 29.5,36 19,29.5 8.5,36 11,23.5 2,15 14.5,14" fill="#f9c31a" stroke="#e6a800" stroke-width="1.2" stroke-linejoin="round"/>
        </svg>
        <span class="ng-star-tooltip">Play a quick game</span>
      </button>
    </div>

  </div>


  {%- comment -%} ── Game overlay ── {%- endcomment -%}
  <div class="ng-overlay" id="{{ section.id }}-overlay">
    <div class="ng-modal">
      <div class="ng-modal-header">
        <p class="ng-modal-title">The BioSkin Peel Protocol game - apply your peel</p>
        <button class="ng-close-btn" id="{{ section.id }}-close" aria-label="Close">&#215;</button>
      </div>

      <div id="{{ section.id }}-game-panel">
        <p class="ng-drop-instruction" id="{{ section.id }}-drop-instruction">Place drops of serum by clicking every spot</p>
        <div class="ng-game-area" id="{{ section.id }}-game-area">
          <img src="{{ section.settings.game_bg_image | image_url: width: 800 }}" alt="Treatment area" draggable="false">
          {%- comment -%} Start overlay sits on top of the image {%- endcomment -%}
          <div class="ng-start-overlay" id="{{ section.id }}-start-screen">
            <div class="ng-start-content" id="{{ section.id }}-start-content">
              <div class="ng-start-icon">&#128137;</div>
              <h2 class="ng-start-title">{{ section.settings.game_start_title }}</h2>
              <p class="ng-start-sub">{{ section.settings.game_start_sub }}</p>
              <button class="ng-start-btn" id="{{ section.id }}-start-btn">{{ section.settings.game_start_cta }}</button>
            </div>
          </div>
        </div>
        <div class="ng-hud">
          <span class="ng-progress-text" id="{{ section.id }}-prog-text">0 / 0</span>
          <div class="ng-progress-bar-wrap">
            <div class="ng-progress-bar" id="{{ section.id }}-prog-bar"></div>
          </div>
          {% comment %}
          <button class="ng-fill-btn" id="{{ section.id }}-fill-btn" title="Testing shortcut">Fill all</button>
          {% endcomment %}
        </div>
      </div>

      <div class="ng-rub-panel" id="{{ section.id }}-rub-panel">
        <p class="ng-rub-instruction">Now rub the serum in — click and drag across the skin</p>
        <div class="ng-rub-area" id="{{ section.id }}-rub-area">
          <img src="{{ section.settings.game_bg_image | image_url: width: 800 }}" alt="Rub serum in" draggable="false">
          <canvas class="ng-rub-canvas" id="{{ section.id }}-rub-canvas"></canvas>
        </div>
        <div class="ng-rub-hud">
          <span class="ng-rub-label">Coverage</span>
          <div class="ng-rub-bar-wrap">
            <div class="ng-rub-bar" id="{{ section.id }}-rub-bar"></div>
          </div>
          <span class="ng-rub-label" id="{{ section.id }}-rub-pct">0%</span>
        </div>
      </div>
      <div class="ng-win-screen" id="{{ section.id }}-win">
        <div class="ng-win-emoji">&#127881;</div>
        <p class="ng-win-title">{{ section.settings.win_title }}</p>
        <p class="ng-win-sub">{{ section.settings.win_message }}</p>
        <div class="ng-code-box">
          <p class="ng-code-label">Your discount code</p>
          <p class="ng-code-value">{{ section.settings.discount_code }}</p>
          <p class="ng-code-label">For $25 off BioRePeelCl3® or BioRePeelCl3® System Kit.</p>
        </div>
        <p class="ng-win-note">{{ section.settings.win_note }}</p>
        <div style="display:flex;gap:10px;justify-content:center;">
         <button class="ng-play-again" id="{{ section.id }}-play-again">Play again</button>
         <a class="ng-play-again" href="/collections/bioskin">Shop Now</a>
        </div>
      </div>
    </div>
  </div>

  <div class="bounce-content">
    {% if section.settings.eyebrow != blank %}<p class="bounce-content__eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
    {% if section.settings.heading != blank %}<h2 class="bounce-content__heading">{{ section.settings.heading }}</h2>{% endif %}
    {% if section.settings.subtext != blank %}<p class="bounce-content__sub">{{ section.settings.subtext }}</p>{% endif %}
    {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
      <a class="bounce-content__cta" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
    {% endif %}
  </div>

</div>

<style>
#{{ section.id }}.bounce-section *,
#{{ section.id }}.bounce-section *::before,
#{{ section.id }}.bounce-section *::after { box-sizing: border-box; }

#{{ section.id }}.bounce-section {
  --bounce-bg:       {{ section.settings.bg_color }};
  --bounce-accent:   {{ section.settings.accent_color }};
  --bounce-text:     {{ section.settings.text_color }};
  --bounce-cta-bg:   {{ section.settings.cta_bg_color }};
  --bounce-cta-text: {{ section.settings.cta_text_color }};
  background-color: var(--bounce-bg);
  padding: {{ section.settings.padding_top | default: 60 }}px 20px {{ section.settings.padding_bottom | default: 60 }}px;
  overflow: visible;
  font-family: inherit;
}

.bounce-stage {
  position: relative;
  width: 100%;
  max-width: 900px;
  margin: 0 auto 48px;
  min-height: 240px;
  overflow: visible;
}

.bounce-bases {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 12px;
  padding: 0 4%;
}

.bounce-base {
  position: relative;
  flex: 1 1 0;
  max-width: 22%;
  display: flex;
  justify-content: center;
  overflow: visible;
}

.bounce-base__img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 12px;
  position: relative;
  z-index: 1;
}

.warmer-glow {
  position: absolute;
  inset: -8px;
  border-radius: 18px;
  background: radial-gradient(ellipse at center, rgba(255,215,0,0.22) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.45s ease;
  pointer-events: none;
  z-index: 0;
}
.bounce-base--4.is-absorbing .warmer-glow { opacity: 1; }

.bounce-base__placeholder {
  width: 100%;
  aspect-ratio: 1 / 2;
  background: rgba(255,255,255,0.08);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.bounce-base__svg { width: 60%; height: auto; opacity: 0.4; }

/* ── Cash explosion ── */
.cash-explosion {
  position: absolute;
  top: 30%;
  left: 50%;
  width: 0;
  height: 0;
  pointer-events: none;
  z-index: 30;
  overflow: visible;
}

.cash-item {
  position: absolute;
  display: block;
  opacity: 0;
  transform-origin: center center;
  animation: none;
}

.cash-bill { width: clamp(34px, 6.5vw, 54px); height: auto; }
.cash-coin { width: clamp(16px, 3vw, 26px); height: auto; }
.cash-sign { font-size: clamp(14px, 2.8vw, 24px); line-height: 1; }

@keyframes cash-fly-bill1  { 0%{opacity:0;transform:translate(0,0) rotate(-10deg) scale(0.3)} 12%{opacity:1} 65%{opacity:1;transform:translate(-120px,-145px) rotate(-38deg) scale(1.1)} 100%{opacity:0;transform:translate(-140px,-95px) rotate(-55deg) scale(0.85)} }
@keyframes cash-fly-bill2  { 0%{opacity:0;transform:translate(0,0) rotate(8deg) scale(0.3)} 12%{opacity:1} 65%{opacity:1;transform:translate(90px,-155px) rotate(28deg) scale(1.1)} 100%{opacity:0;transform:translate(110px,-105px) rotate(44deg) scale(0.85)} }
@keyframes cash-fly-bill3  { 0%{opacity:0;transform:translate(0,0) rotate(-22deg) scale(0.3)} 12%{opacity:1} 65%{opacity:1;transform:translate(-170px,-65px) rotate(-48deg) scale(1.0)} 100%{opacity:0;transform:translate(-190px,-18px) rotate(-64deg) scale(0.8)} }
@keyframes cash-fly-bill4  { 0%{opacity:0;transform:translate(0,0) rotate(16deg) scale(0.3)} 12%{opacity:1} 65%{opacity:1;transform:translate(150px,-95px) rotate(42deg) scale(1.0)} 100%{opacity:0;transform:translate(170px,-42px) rotate(58deg) scale(0.8)} }
@keyframes cash-fly-bill5  { 0%{opacity:0;transform:translate(0,0) rotate(-4deg) scale(0.25)} 12%{opacity:1} 65%{opacity:1;transform:translate(-28px,-178px) rotate(-22deg) scale(1.15)} 100%{opacity:0;transform:translate(-18px,-125px) rotate(-34deg) scale(0.92)} }
@keyframes cash-fly-coin1  { 0%{opacity:0;transform:translate(0,0) scale(0.25) rotate(0deg)} 18%{opacity:1} 60%{opacity:1;transform:translate(-95px,-118px) scale(1.2) rotate(200deg)} 100%{opacity:0;transform:translate(-115px,-66px) scale(0.9) rotate(380deg)} }
@keyframes cash-fly-coin2  { 0%{opacity:0;transform:translate(0,0) scale(0.25) rotate(0deg)} 18%{opacity:1} 60%{opacity:1;transform:translate(78px,-128px) scale(1.2) rotate(-215deg)} 100%{opacity:0;transform:translate(98px,-76px) scale(0.9) rotate(-415deg)} }
@keyframes cash-fly-coin3  { 0%{opacity:0;transform:translate(0,0) scale(0.25) rotate(0deg)} 18%{opacity:1} 60%{opacity:1;transform:translate(128px,-55px) scale(1.1) rotate(235deg)} 100%{opacity:0;transform:translate(148px,-8px) scale(0.8) rotate(460deg)} }
@keyframes cash-fly-coin4  { 0%{opacity:0;transform:translate(0,0) scale(0.25) rotate(0deg)} 18%{opacity:1} 60%{opacity:1;transform:translate(-128px,-44px) scale(1.1) rotate(-255deg)} 100%{opacity:0;transform:translate(-148px,4px) scale(0.8) rotate(-500deg)} }
@keyframes cash-fly-sign1  { 0%{opacity:0;transform:translate(0,0) scale(0.2)} 18%{opacity:1} 62%{opacity:1;transform:translate(55px,-168px) scale(1.35)} 100%{opacity:0;transform:translate(65px,-116px) scale(1.1)} }
@keyframes cash-fly-sign2  { 0%{opacity:0;transform:translate(0,0) scale(0.2)} 18%{opacity:1} 62%{opacity:1;transform:translate(-65px,-148px) scale(1.45)} 100%{opacity:0;transform:translate(-76px,-96px) scale(1.1)} }
@keyframes cash-fly-sign3  { 0%{opacity:0;transform:translate(0,0) scale(0.2)} 18%{opacity:1} 62%{opacity:1;transform:translate(168px,-115px) scale(1.2)} 100%{opacity:0;transform:translate(188px,-62px) scale(0.95)} }

.bounce-base--4.is-absorbing .cash-bill--1 { animation: cash-fly-bill1 1.15s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay: 120ms; }
.bounce-base--4.is-absorbing .cash-bill--2 { animation: cash-fly-bill2 1.20s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay:  55ms; }
.bounce-base--4.is-absorbing .cash-bill--3 { animation: cash-fly-bill3 1.05s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay: 205ms; }
.bounce-base--4.is-absorbing .cash-bill--4 { animation: cash-fly-bill4 1.18s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay:   0ms; }
.bounce-base--4.is-absorbing .cash-bill--5 { animation: cash-fly-bill5 1.08s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay: 155ms; }
.bounce-base--4.is-absorbing .cash-coin--1 { animation: cash-fly-coin1 0.98s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay:  82ms; }
.bounce-base--4.is-absorbing .cash-coin--2 { animation: cash-fly-coin2 1.02s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay:  28ms; }
.bounce-base--4.is-absorbing .cash-coin--3 { animation: cash-fly-coin3 0.92s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay: 182ms; }
.bounce-base--4.is-absorbing .cash-coin--4 { animation: cash-fly-coin4 1.08s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay: 102ms; }
.bounce-base--4.is-absorbing .cash-sign--1 { animation: cash-fly-sign1 1.12s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay:  48ms; }
.bounce-base--4.is-absorbing .cash-sign--2 { animation: cash-fly-sign2 1.02s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay: 132ms; }
.bounce-base--4.is-absorbing .cash-sign--3 { animation: cash-fly-sign3 0.97s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay: 225ms; }

/* Also allow mobile 3rd base to trigger cash (it's the warmer on mobile) */
.bounce-base--3.is-absorbing .warmer-glow { opacity: 1; }
.bounce-base--3.is-absorbing .cash-bill--1 { animation: cash-fly-bill1 1.15s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay: 120ms; }
.bounce-base--3.is-absorbing .cash-bill--2 { animation: cash-fly-bill2 1.20s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay:  55ms; }
.bounce-base--3.is-absorbing .cash-bill--3 { animation: cash-fly-bill3 1.05s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay: 205ms; }
.bounce-base--3.is-absorbing .cash-bill--4 { animation: cash-fly-bill4 1.18s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay:   0ms; }
.bounce-base--3.is-absorbing .cash-bill--5 { animation: cash-fly-bill5 1.08s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay: 155ms; }
.bounce-base--3.is-absorbing .cash-coin--1 { animation: cash-fly-coin1 0.98s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay:  82ms; }
.bounce-base--3.is-absorbing .cash-coin--2 { animation: cash-fly-coin2 1.02s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay:  28ms; }
.bounce-base--3.is-absorbing .cash-coin--3 { animation: cash-fly-coin3 0.92s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay: 182ms; }
.bounce-base--3.is-absorbing .cash-coin--4 { animation: cash-fly-coin4 1.08s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay: 102ms; }
.bounce-base--3.is-absorbing .cash-sign--1 { animation: cash-fly-sign1 1.12s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay:  48ms; }
.bounce-base--3.is-absorbing .cash-sign--2 { animation: cash-fly-sign2 1.02s cubic-bezier(0.22,1,0.36,1) forwards; animation-delay: 132ms; }

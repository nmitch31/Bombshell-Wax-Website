/* ── Traveller ── */
.bounce-traveller {
  position: absolute;
  width: 22%;
  max-width: 22%;
  top: 0; left: 4%;
  pointer-events: none;
  will-change: transform, opacity;
  z-index: 10;
  transform-origin: center bottom;
}
.bounce-traveller img,
.bounce-traveller .bounce-base__placeholder {
  width: 100%; height: auto; border-radius: 12px; display: block;
}

/* ── Text ── */
.bounce-content { text-align: center; max-width: 740px; margin: 0 auto; padding: 0 16px; }
.bounce-content__eyebrow { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--bounce-accent); margin: 0 0 12px; }
.bounce-content__heading { font-size: clamp(1.6rem, 4vw, 2.8rem); font-weight: 800; line-height: 1.15; color: var(--bounce-text); margin: 0 0 16px; }
.bounce-content__sub { font-size: clamp(0.95rem, 2vw, 1.1rem); line-height: 1.65; color: var(--bounce-text); opacity: 0.75; margin: 0 0 28px; }
.bounce-content__cta { display: inline-block; background: var(--bounce-cta-bg); color: var(--bounce-cta-text); padding: 14px 36px; border-radius: 100px; font-size: 0.95rem; font-weight: 700; letter-spacing: 0.04em; text-decoration: none; transition: opacity 0.2s ease, transform 0.2s ease; }
.bounce-content__cta:hover { opacity: 0.88; transform: translateY(-2px); color: var(--bounce-cta-text); }


/* ── Star button ── */
.ng-star-wrap {
  position: absolute;
  top: 0;
  left: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s ease;
  transform: translate(-50%, calc(-100% - 10px));
}
.ng-star-wrap.ng-star-visible {
  opacity: 1;
  pointer-events: all;
}
.ng-star-btn {
  position: relative;
  background: none;
  border: none;
  /* Larger tap target on mobile */
  padding: 12px;
  cursor: pointer;
  width: 62px;
  height: 62px;
  display: flex;
  align-items: center;
  justify-content: center;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}
.ng-star-icon {
  width: 38px;
  height: 38px;
  filter: drop-shadow(0 0 5px rgba(249,195,26,0.7));
  animation: ng-star-pulse 1.8s ease-in-out infinite;
}
@keyframes ng-star-pulse {
  0%,100% { transform: scale(1); }
  50%      { transform: scale(1.2); }
}
.ng-star-btn:hover .ng-star-icon {
  animation-play-state: paused;
}
.ng-star-tooltip {
  position: absolute;
  bottom: calc(100% + 6px);
  left: 50%;
  transform: translateX(-50%);
  background: #fff;
  color: #111;
  border-radius: 6px;
  padding: 4px 10px;
  font-size: 11px;
  white-space: nowrap;
  pointer-events: none;
  opacity: 1;
  box-shadow: 0 2px 8px rgba(0,0,0,0.18);
}


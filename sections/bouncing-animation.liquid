/* ── Start screen ── */
/* Overlay sits absolutely on top of the game image */
.ng-start-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.52);
  z-index: 20;
  transition: opacity 0.55s ease;
  pointer-events: all;
}
.ng-start-overlay.ng-fading {
  opacity: 0;
  pointer-events: none;
}
.ng-start-overlay.ng-gone {
  display: none;
}
.ng-start-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 32px 28px;
  transition: opacity 0.4s ease, transform 0.4s ease;
}
.ng-start-content.ng-fading {
  opacity: 0;
  transform: translateY(-12px);
}
.ng-start-icon {
  font-size: 52px;
  margin-bottom: 18px;

    {x:33.6,y:46.5},
    {x:31.3,y:52},
    {x:25.1,y:48.5},
    {x:20.8,y:45.1},
    {x:18.4,y:49.8},
    {x:23.9,y:53.1},
    {x:17.9,y:57.1},
    {x:23.9,y:63.3},
    {x:28.3,y:65.5},
    {x:33.8,y:63.1},
    {x:40.6,y:65.3},
    {x:41.8,y:60.6},
    {x:44.8,y:58},
    {x:47.6,y:61.6},
    {x:51.6,y:58.3},
    {x:56.9,y:61.8},
    {x:60.4,y:59.1},
    {x:61.6,y:63.1},
    {x:65.9,y:56.3},
    {x:65.9,y:60.8},
    {x:71.3,y:61.5},
    {x:71.3,y:66},
    {x:73.4,y:71.1},
    {x:74.4,y:73.8},
    {x:66.6,y:77.6},
    {x:66.6,y:69.5},
    {x:58.9,y:68.8},
    {x:55.4,y:71.8},
    {x:54.9,y:77.3},
    {x:52.3,y:73.5},
    {x:50.1,y:68.6},
    {x:45.4,y:66.1},
    {x:43.6,y:70.8},
    {x:49.1,y:72.1},
    {x:44.9,y:77},
    {x:40.9,y:78},
    {x:34.4,y:71.6},
    {x:34.9,y:77.1},
    {x:26.6,y:76},
    {x:22.1,y:75.3}

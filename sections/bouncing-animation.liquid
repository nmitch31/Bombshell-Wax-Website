  line-height: 1.65;
  max-width: 300px;
  text-shadow: 0 1px 4px rgba(0,0,0,0.5);
}
.ng-start-btn {
  background: #19d2c6;
  color: #111;
  border: none;
  border-radius: 100px;
  padding: 13px 40px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  font-family: inherit;
  letter-spacing: 0.03em;
  transition: opacity 0.2s ease, transform 0.15s ease;
}
.ng-start-btn:hover {
  opacity: 0.88;
  transform: translateY(-2px);
}
/* Drop targets start invisible and fade in after start screen clears */
.ng-drop-target {
  opacity: 0;
  transition: opacity 2.1s ease;
}
.ng-drop-target.ng-visible {
  opacity: 1;
}


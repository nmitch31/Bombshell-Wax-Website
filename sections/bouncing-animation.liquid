  function init(sectionId) {
    var section   = document.getElementById(sectionId);
    if (!section) return;

    var traveller = section.querySelector('.bounce-traveller');
    var bases     = section.querySelectorAll('.bounce-base');
    var stage     = section.querySelector('.bounce-stage');
    if (!traveller || bases.length < 3 || !stage) return;

    /* ── Shared helpers ── */
    function isMobile() { return window.innerWidth <= 600; }

    /* ════════════════════════════════════════
       BOUNCE ANIMATION
    ════════════════════════════════════════ */
    var TRAVEL_DUR = {{ section.settings.animation_speed | default: 2200 }};
    var BOUNCE_PCT = {{ section.settings.bounce_height   | default: 55 }};
    var HOLD_DUR   = TRAVEL_DUR * 0.6;
    var raf        = null;
    var started    = false;
    var segments   = [];
    var segIdx     = 0;
    var segStart   = null;

    function getBasePos(base) {
      var sr = stage.getBoundingClientRect();
      var br = base.getBoundingClientRect();
      var tr = traveller.getBoundingClientRect();
      var tw = tr.width  || br.width;
      var th = tr.height || br.height;
      return {
        x: br.left - sr.left + (br.width  / 2) - (tw / 2) - (isMobile() ? 10 : 20),
        y: br.top  - sr.top  + (br.height / 2) - (th / 2)
      };
    }

    function easeInOutQuad(t) { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }
    function easeInQuart(t)   { return t*t*t*t; }

    function buildSegments() {
      segments = [];
      var pos = Array.prototype.map.call(bases, getBasePos);
      var arc = traveller.offsetHeight * BOUNCE_PCT / 100;
      if (isMobile()) {
        segments.push({ type:'bounce', from:pos[1], to:pos[2], arcH:arc,        dur:TRAVEL_DUR });
        segments.push({ type:'absorb', from:pos[2], to:pos[3], arcH:arc * 0.55, dur:TRAVEL_DUR });
        segments.push({ type:'hold',   pos:pos[3],                               dur:HOLD_DUR   });
        segments.push({ type:'reset',  pos:pos[1] });
      } else {
        segments.push({ type:'bounce', from:pos[0], to:pos[1], arcH:arc,        dur:TRAVEL_DUR });
        segments.push({ type:'bounce', from:pos[1], to:pos[2], arcH:arc,        dur:TRAVEL_DUR });
        segments.push({ type:'absorb', from:pos[2], to:pos[3], arcH:arc * 0.55, dur:TRAVEL_DUR });
        segments.push({ type:'hold',   pos:pos[3],                               dur:HOLD_DUR   });
        segments.push({ type:'reset',  pos:pos[0] });
      }
    }

    function applyTraveller(x, y, opacity, scale) {
      traveller.style.transform = 'translate(' + x + 'px,' + y + 'px) scale(' + scale + ')';
      traveller.style.opacity   = opacity;
    }

    function triggerAbsorption(on) {
      var warmerIdx = isMobile() ? 2 : 3;
      var warmer    = bases[warmerIdx];
      if (!warmer) return;
      if (on) {
        warmer.classList.remove('is-absorbing');
        void warmer.offsetWidth;
        warmer.classList.add('is-absorbing');
      } else {
        warmer.classList.remove('is-absorbing');
      }
    }

    function step(ts) {
      if (!segStart) segStart = ts;
      var seg = segments[segIdx];
      if (!seg) { segIdx = 0; segStart = ts; raf = requestAnimationFrame(step); return; }

      if (seg.type === 'hold') {
        applyTraveller(seg.pos.x, seg.pos.y, 0, 0.05);
        if (ts - segStart >= seg.dur) {
          triggerAbsorption(false);
          segIdx++;
          segStart = null;
        }
        raf = requestAnimationFrame(step);
        return;
      }

      if (seg.type === 'reset') {
        if (raf) { cancelAnimationFrame(raf); raf = null; }
        traveller.style.transition = 'none';
        applyTraveller(seg.pos.x, seg.pos.y, 0, 1);
        requestAnimationFrame(function () {
          traveller.style.transition = 'opacity 0.38s ease';
          traveller.style.opacity    = '1';
          setTimeout(function () {
            traveller.style.transition = '';
            segIdx++;
            segStart = null;
            raf = requestAnimationFrame(step);
            /* Show star after first complete loop */

          }, 400);
        });
        return;
      }

      if (seg.type === 'bounce') {
        var el = ts - segStart;
        var t  = Math.min(el / seg.dur, 1);
        var te = easeInOutQuad(t);
        var x  = seg.from.x + (seg.to.x - seg.from.x) * te;
        var ay = -4 * seg.arcH * t * (t - 1);
        var y  = seg.from.y + (seg.to.y - seg.from.y) * te - ay;
        applyTraveller(x, y, 1, 1);
        if (t >= 1) { segIdx++; segStart = null; }
        raf = requestAnimationFrame(step);
        return;
      }

      if (seg.type === 'absorb') {
        var el2 = ts - segStart;
        var t2  = Math.min(el2 / seg.dur, 1);
        var te2 = easeInOutQuad(t2);
        var x2  = seg.from.x + (seg.to.x - seg.from.x) * te2;
        var ay2 = -4 * seg.arcH * t2 * (t2 - 1);
        var y2  = seg.from.y + (seg.to.y - seg.from.y) * te2 - ay2;
        var ap  = Math.max(0, (t2 - 0.65) / 0.35);
        applyTraveller(x2, y2, 1 - easeInQuart(ap), 1 - easeInQuart(ap) * 0.95);
        if (t2 >= 1) {
          applyTraveller(seg.to.x, seg.to.y, 0, 0.05);
          triggerAbsorption(true);
          segIdx++;
          segStart = null;
        }
        raf = requestAnimationFrame(step);
        return;
      }

      raf = requestAnimationFrame(step);
    }

    function startAnimation() {
      if (started) return;
      started = true;
      buildSegments();
      if (segments.length > 0) applyTraveller(segments[0].from.x, segments[0].from.y, 1, 1);
      raf = requestAnimationFrame(step);
      /* Show star immediately — small delay lets layout settle first */
      setTimeout(showStar, 300);
    }

    function stopAnimation() {
      if (raf) { cancelAnimationFrame(raf); raf = null; }
      started  = false;
      segIdx   = 0;
      segStart = null;
      triggerAbsorption(false);
      traveller.style.transition = '';
      traveller.style.opacity    = '1';
      traveller.style.transform  = '';
    }

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) { startAnimation(); }
        else                      { stopAnimation();  }
      });
    }, { threshold: 0.25 });
    observer.observe(section);

    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        if (started) { stopAnimation(); startAnimation(); }
      }, 200);
    });

    /* ════════════════════════════════════════
       MINI-GAME
    ════════════════════════════════════════ */
    var starWrap  = document.getElementById(sectionId + '-star');
    var starBtn   = document.getElementById(sectionId + '-star-btn');
    var overlay   = document.getElementById(sectionId + '-overlay');
    var closeBtn  = document.getElementById(sectionId + '-close');
    var gamePanel = document.getElementById(sectionId + '-game-panel');
    var gameArea  = document.getElementById(sectionId + '-game-area');
    var winScreen = document.getElementById(sectionId + '-win');
    var progText  = document.getElementById(sectionId + '-prog-text');
    var progBar   = document.getElementById(sectionId + '-prog-bar');
    var playAgain = document.getElementById(sectionId + '-play-again');

    var gameTotal = DROP_POS.length;
    var gameHit   = 0;

    /* Position the star above the warmer image and reveal it */
    function showStar() {
      if (!starWrap || !stage) return;
      if (isMobile()) {
        /* Mobile: position above the warmer (last visible base) */
        var warmerEl = bases[3] || bases[bases.length - 1];
        if (warmerEl) {
          var wr = warmerEl.getBoundingClientRect();
          var sr = stage.getBoundingClientRect();
          starWrap.style.left = (wr.left - sr.left + wr.width / 2) + 'px';
          starWrap.style.top  = (wr.top  - sr.top) + 'px';
        }
      } else {
        /* Desktop: centred horizontally on the stage, above the base row */
        var sr = stage.getBoundingClientRect();
        /* Find the top of the base images to position just above them */
        var firstBase = bases[0];
        var topY = firstBase
          ? (firstBase.getBoundingClientRect().top - sr.top)
          : 0;
        starWrap.style.left = (sr.width / 2) + 'px';
        starWrap.style.top  = topY + 'px';
      }
      starWrap.classList.add('ng-star-visible');
    }

    /* ── extra DOM refs for rub phase ── */
    var rubPanel  = document.getElementById(sectionId + '-rub-panel');
    var rubArea   = document.getElementById(sectionId + '-rub-area');
    var rubCanvas = document.getElementById(sectionId + '-rub-canvas');
    var rubBar    = document.getElementById(sectionId + '-rub-bar');
    var rubPct    = document.getElementById(sectionId + '-rub-pct');

    /* ── Phase 1: needle drop ── */
    function buildGameTargets() {
      gameArea.querySelectorAll('.ng-drop-target').forEach(function(el) { el.remove(); });
      gameHit = 0;
      gameArea.classList.remove('ng-cursor-glove', 'ng-cursor-default');
      gameArea.classList.add('ng-cursor-needle');
      updateHUD();
      DROP_POS.forEach(function(pos, i) {
        var el = document.createElement('div');
        el.className = 'ng-drop-target';
        el.style.left = pos.x + '%';
        el.style.top  = pos.y + '%';
        el.setAttribute('aria-label', 'Drop spot ' + (i + 1));
        el.addEventListener('click', function() { hitTarget(el); });
        gameArea.appendChild(el);
      });
    }

    function hitTarget(el) {
      if (el.classList.contains('ng-hit')) return;
      el.classList.add('ng-hit');
      gameHit++;
      updateHUD();
      /* Switch cursor to glove only once ALL drops are placed */
      if (gameHit >= gameTotal) gameArea.classList.add('ng-cursor-glove');
      if (gameHit >= gameTotal) setTimeout(startRubPhase, 600);
    }

    function updateHUD() {
      if (progText) progText.textContent = gameHit + ' / ' + gameTotal;
      if (progBar)  progBar.style.width  = (gameTotal > 0 ? (gameHit / gameTotal) * 100 : 0) + '%';
    }

    var fillBtn = document.getElementById(sectionId + '-fill-btn');

    function fillAllSpots() {
      gameArea.querySelectorAll('.ng-drop-target:not(.ng-hit)').forEach(function(el) {
        el.classList.add('ng-hit');
        gameHit++;
      });
      updateHUD();
      if (gameHit >= gameTotal) {
        gameArea.classList.add('ng-cursor-glove');
        setTimeout(startRubPhase, 600);
      }
    }

    if (fillBtn) fillBtn.addEventListener('click', fillAllSpots);

    /* ── Phase 2: rub-in ── */
    var RUB_TARGET   = 98;  /* % of zone cells that must be covered */
    var rubbing      = false;
    var rubCoverage  = 0;
    var rubCtx       = null;
    var rubComplete  = false;
    var coveredCells = {};   /* keys of zone cells the brush has touched */
    var zoneCells    = {};   /* keys of ALL cells inside the drop zone */
    var zoneCellCount = 0;
    var CELL_SIZE    = 16;   /* px — smaller = more precise coverage tracking */

    /* Drop zone polygon — convex hull of the drop positions (in % units).
       Traced to tightly bound the armpit treatment area in the image.      */
    var ZONE_POLY_PCT = [
      {x:14.4,y:56.7},
      {x:15.2,y:48.4},
      {x:18.0,y:43.0},
      {x:21.3,y:37.7},
      {x:50.5,y:37.4},
      {x:61.3,y:42.7},
      {x:74.8,y:61.7},
      {x:77.6,y:75.1},
      {x:69.5,y:79.6},
      {x:40.9,y:81.5},
      {x:24.3,y:78.6},
      {x:19.4,y:77.5}
    ];

    /* Point-in-polygon test (ray casting) */
    function pointInPoly(px, py, poly) {
      var inside = false;
      for (var i = 0, j = poly.length - 1; i < poly.length; j = i++) {
        var xi = poly[i].x, yi = poly[i].y;
        var xj = poly[j].x, yj = poly[j].y;
        if (((yi > py) !== (yj > py)) && (px < (xj - xi) * (py - yi) / (yj - yi) + xi)) {
          inside = !inside;
        }
      }
      return inside;
    }

    /* Build the set of grid cells that fall inside the zone polygon.
       Called once per game start after canvas dimensions are known.  */
    function buildZoneCells(canvasW, canvasH) {
      zoneCells     = {};
      zoneCellCount = 0;
      var cols = Math.ceil(canvasW / CELL_SIZE);
      var rows = Math.ceil(canvasH / CELL_SIZE);
      for (var row = 0; row < rows; row++) {
        for (var col = 0; col < cols; col++) {
          /* Centre of this cell in % */
          var pctX = ((col + 0.5) * CELL_SIZE / canvasW) * 100;
          var pctY = ((row + 0.5) * CELL_SIZE / canvasH) * 100;
          if (pointInPoly(pctX, pctY, ZONE_POLY_PCT)) {
            var key = col + ',' + row;
            zoneCells[key] = true;
            zoneCellCount++;
          }
        }
      }
    }

    /* Draw the zone outline on the canvas so the player knows where to rub */
    function drawZoneOutline(canvasW, canvasH) {
      if (!rubCtx) return;
      rubCtx.save();
      rubCtx.beginPath();
      var first = ZONE_POLY_PCT[0];
      rubCtx.moveTo(first.x / 100 * canvasW, first.y / 100 * canvasH);
      for (var i = 1; i < ZONE_POLY_PCT.length; i++) {
        rubCtx.lineTo(ZONE_POLY_PCT[i].x / 100 * canvasW, ZONE_POLY_PCT[i].y / 100 * canvasH);
      }
      rubCtx.closePath();
      rubCtx.strokeStyle = 'rgba(249,195,26,0.7)';
      rubCtx.lineWidth   = 2.5;
      rubCtx.setLineDash([8, 5]);
      rubCtx.stroke();
      rubCtx.restore();
    }

    function startRubPhase() {
      if (gamePanel) gamePanel.style.display = 'none';
      if (rubPanel)  rubPanel.classList.add('ng-visible');
      initRubCanvas();
    }

    function initRubCanvas() {
      if (!rubCanvas || !rubArea) return;
      rubComplete   = false;
      rubCoverage   = 0;
      coveredCells  = {};
      var w = rubArea.offsetWidth;
      var h = rubArea.offsetHeight;
      rubCanvas.width  = w;
      rubCanvas.height = h;
      rubCtx = rubCanvas.getContext('2d');
      rubCtx.clearRect(0, 0, w, h);

      /* Build zone cell set and draw the guide outline */
      buildZoneCells(w, h);
      drawZoneOutline(w, h);
      updateRubBar(0);

      function getPos(e) {
        var r = rubArea.getBoundingClientRect();
        var src = e.touches ? e.touches[0] : e;
        return { x: src.clientX - r.left, y: src.clientY - r.top };
      }

      function onStart(e) {
        if (rubComplete) return;
        e.preventDefault();
        rubbing = true;
        paint(getPos(e));
      }

      function onMove(e) {
        if (!rubbing || rubComplete) return;
        e.preventDefault();
        paint(getPos(e));
      }

      function onEnd() { rubbing = false; }

      /* Remove any old listeners before adding new ones (safe for replay) */
      var fresh = rubArea.cloneNode(true);
      rubArea.parentNode.replaceChild(fresh, rubArea);
      rubArea = fresh;
      /* Re-acquire canvas ref after clone */
      rubCanvas = document.getElementById(sectionId + '-rub-canvas');
      rubCtx    = rubCanvas.getContext('2d');
      rubCanvas.width  = w;
      rubCanvas.height = h;
      rubCtx.clearRect(0, 0, w, h);
      buildZoneCells(w, h);
      drawZoneOutline(w, h);

      rubArea.addEventListener('mousedown',  onStart);
      rubArea.addEventListener('mousemove',  onMove);
      rubArea.addEventListener('mouseup',    onEnd);
      rubArea.addEventListener('mouseleave', onEnd);
      rubArea.addEventListener('touchstart', onStart, { passive: false });
      rubArea.addEventListener('touchmove',  onMove,  { passive: false });
      rubArea.addEventListener('touchend',   onEnd);
    }

    function paint(pos) {
      if (!rubCtx || zoneCellCount === 0) return;
      var radius  = 24;
      var canvasW = rubCanvas.width;
      var canvasH = rubCanvas.height;

      /* Only paint if the cursor centre is within (or near) the zone */
      var pctX = (pos.x / canvasW) * 100;
      var pctY = (pos.y / canvasH) * 100;
      var nearZone = pointInPoly(pctX, pctY, ZONE_POLY_PCT);
      if (!nearZone) return;

      /* Draw translucent pink smear, clipped to the zone path */
      rubCtx.save();
      rubCtx.beginPath();
      var first = ZONE_POLY_PCT[0];
      rubCtx.moveTo(first.x / 100 * canvasW, first.y / 100 * canvasH);
      for (var i = 1; i < ZONE_POLY_PCT.length; i++) {
        rubCtx.lineTo(ZONE_POLY_PCT[i].x / 100 * canvasW, ZONE_POLY_PCT[i].y / 100 * canvasH);
      }
      rubCtx.closePath();
      rubCtx.clip();

      rubCtx.beginPath();
      rubCtx.arc(pos.x, pos.y, radius, 0, Math.PI * 2);
      rubCtx.fillStyle = 'rgba(244,143,177,0.38)';
      rubCtx.fill();
      rubCtx.restore();

      /* Redraw zone outline on top so it stays visible */
      drawZoneOutline(canvasW, canvasH);

      /* Mark zone cells touched by this brush stroke */
      var col = Math.floor(pos.x / CELL_SIZE);
      var row = Math.floor(pos.y / CELL_SIZE);
      var reach = Math.ceil(radius / CELL_SIZE) + 1;
      for (var dx = -reach; dx <= reach; dx++) {
        for (var dy = -reach; dy <= reach; dy++) {
          var key = (col + dx) + ',' + (row + dy);
          if (zoneCells[key] && !coveredCells[key]) {
            coveredCells[key] = true;
          }
        }
      }

      /* Coverage = covered zone cells / total zone cells.
         Scale display so RUB_TARGET reads as 100% to the player. */
      var covered = Object.keys(coveredCells).length;
      var rawPct  = covered / zoneCellCount * 100;
      rubCoverage = Math.min(100, Math.round(rawPct));
      var displayPct = Math.min(100, Math.round(rawPct / RUB_TARGET * 100));
      updateRubBar(displayPct);

      if (rubCoverage >= RUB_TARGET && !rubComplete) {
        rubComplete = true;
        setTimeout(showWin, 700);
      }
    }

    function updateRubBar(pct) {
      if (rubBar) rubBar.style.width = pct + '%';
      if (rubPct) rubPct.textContent = pct + '%';
    }

    function showWin() {
      if (rubPanel)  rubPanel.classList.remove('ng-visible');
      if (gamePanel) gamePanel.style.display = 'none';
      if (winScreen) winScreen.classList.add('ng-visible');
    }

    function resetGame(skipFadeIn) {
      if (winScreen) winScreen.classList.remove('ng-visible');
      if (rubPanel)  rubPanel.classList.remove('ng-visible');
      if (gamePanel) gamePanel.style.display = '';
      if (rubCtx)    rubCtx.clearRect(0, 0, rubCanvas.width, rubCanvas.height);
      rubComplete = false;
      rubCoverage = 0;
      coveredCells = {};
      updateRubBar(0);
      buildGameTargets();
      /* On Play Again: show targets immediately without fade-in delay */
      if (skipFadeIn) {
        if (gameArea) {
          gameArea.querySelectorAll('.ng-drop-target').forEach(function(el) {
            el.classList.add('ng-visible');
          });
        }
      }
    }

    var startScreen = document.getElementById(sectionId + '-start-screen');
    var startBtn    = document.getElementById(sectionId + '-start-btn');

    var startContent = document.getElementById(sectionId + '-start-content');

    function showStartScreen() {
      var dropInstr = document.getElementById(sectionId + '-drop-instruction');
      if (dropInstr) dropInstr.style.display = 'none';
      /* Reset overlay to fully visible */
      if (startScreen) {
        startScreen.classList.remove('ng-fading', 'ng-gone');
      }
      if (startContent) {
        startContent.classList.remove('ng-fading');
      }
      if (gamePanel)   gamePanel.style.display = '';
      if (rubPanel)    rubPanel.classList.remove('ng-visible');
      if (winScreen)   winScreen.classList.remove('ng-visible');
      /* Hide drop targets instantly on reset */
      if (gameArea) {
        gameArea.querySelectorAll('.ng-drop-target').forEach(function(el) {
          el.classList.remove('ng-visible');
        });
      }
    }

    function beginGame() {
      /* Step 1: fade the text/button content out (0.4s) */
      if (startContent) startContent.classList.add('ng-fading');

      setTimeout(function() {
        /* Step 2: fade the dark overlay out (0.55s) */
        if (startScreen) startScreen.classList.add('ng-fading');

        setTimeout(function() {
          /* Step 3: hide overlay completely, then fade drop targets in */
          if (startScreen) startScreen.classList.add('ng-gone');
          if (gameArea) gameArea.classList.add('ng-cursor-needle');
          var dropInstr = document.getElementById(sectionId + '-drop-instruction');
          if (dropInstr) dropInstr.style.display = 'block';
          resetGame();
          /* Stagger each drop target fading in */
          if (gameArea) {
            var targets = gameArea.querySelectorAll('.ng-drop-target');
            targets.forEach(function(el, i) {
              setTimeout(function() {
                el.classList.add('ng-visible');
              }, i * 30);
            });
          }
        }, 580);
      }, 420);
    }

    if (startBtn) startBtn.addEventListener('click', beginGame);

    function openOverlay() {
      if (overlay) {
        overlay.classList.add('ng-open');
      }
      showStartScreen();
    }

    function closeOverlay() {
      if (overlay) {
        overlay.style.opacity = '0';
        overlay.style.transition = 'opacity 0.2s ease';
        setTimeout(function() {
          overlay.classList.remove('ng-open');
          overlay.style.opacity = '';
          overlay.style.transition = '';
        }, 200);
      }
      /* Reset cursor classes so needle doesn't bleed outside the overlay */
      if (gameArea) gameArea.classList.remove('ng-cursor-needle', 'ng-cursor-glove', 'ng-cursor-default');
    }

    if (starBtn) {
      starBtn.addEventListener('click', openOverlay);
      starBtn.addEventListener('touchend', function(e) {
        e.preventDefault();
        openOverlay();
      });
    }
    if (closeBtn) closeBtn.addEventListener('click', closeOverlay);
    if (playAgain) playAgain.addEventListener('click', function() { resetGame(true); });
    if (overlay) {
      overlay.addEventListener('click', function(e) {
        if (e.target === overlay) closeOverlay();
      });
    }
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeOverlay();
    });

    if (gameArea) { buildGameTargets(); updateHUD(); }
  }

  function onReady(fn) {
    if (document.readyState !== 'loading') { fn(); }
    else { document.addEventListener('DOMContentLoaded', fn); }
  }

  onReady(function () { init('{{ section.id }}'); });

  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail && e.detail.sectionId === '{{ section.id }}') {
      init('{{ section.id }}');
    }
  });

  /* Auto-open game + scroll to section if URL hash is #play */
  onReady(function () {
    if (window.location.hash === '#play') {
      var attempts = 0;
      var tryOpen = setInterval(function () {
        var section = document.getElementById('{{ section.id }}');
        var btn     = document.getElementById('{{ section.id }}-star-btn');
        if (section && btn) {
          /* Scroll the section into view first, then open the game */
          section.scrollIntoView({ behavior: 'smooth', block: 'center' });
          setTimeout(function () { btn.click(); }, 600);
          clearInterval(tryOpen);
        }
        if (++attempts > 25) clearInterval(tryOpen); /* give up after 5s */
      }, 200);
    }
  });
})();
</script>


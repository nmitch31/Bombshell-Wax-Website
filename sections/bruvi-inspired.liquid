<style>
    .floating-pods {
  position: relative;
  padding-top: 0;
  @media (min-width: 768px) {
    min-height: 40vw;
    display: flex;
    align-items: flex-end;
  }
  .pods-container {
    position: relative;
    overflow: hidden;
    top: 0;
    left: 0;
    width: 100%;
    height: 68vw;
    margin-bottom: -5vw;
    z-index: 1;
    @media (min-width: 768px) {
      position: absolute;
      height: 100%;
    }
    .pod {
      position: absolute;
      width: 33%;
      height: auto;
      @media (min-width: 768px) {
        width: 21%;
      }
      img {
        width: 100%;
      }
      &.pod-1 {
        left: 5%;
        top: 0%;
        transform: rotate(-15deg);
        display: block;  
      }
      &.pod-2 {
        left: 43%;
        top: 0%;
        display: block;
      }
      &.pod-3 {
        left: 76%;
        top: 0%;
        display: none;
        transform: rotate(15deg);
        display: block;
      }
      &.pod-4 {
        transform: rotate(-10deg);
        left: 15%;
        top: 32%;
        @media (min-width: 992px) and (max-width: 1664px) {
        left: 10%;
        top: 25%;
        }
        @media (min-width: 511px) and (max-width: 991px) {
        left: 76%;
        top: 13%;
        }
        @media (min-width: 321px) and (max-width: 510px) {
        left: 80%;
        top: 9%;
        }
        @media (max-width: 320px) {
        display: none;
        }
      }
      &.pod-5 {
        transform: rotate(5deg);
        left: 65%;
        top: 33%;
        @media (min-width: 992px) and (max-width: 1664px) {
        left: 68%;
        top: 23%;
        }
        @media (min-width: 511px) and (max-width: 991px) {
        left: 6%;
        top: 13%;
        }
         @media (min-width: 321px) and (max-width: 510px) {
        left: 2%;
        top: 9%;
        }
        @media (max-width: 320px) {
        display: none;
        }
      }
      &.pod-6 {
        left: 83%;
        top: 20%;
      }
      &.pod-7 {
        left: 3%;
        top: 60%;
        @media (max-width: 991px) {
            display: none;
        }
        
      }
      &.pod-8 {
        transform: rotate(-20deg);
        left: 75%;
        top: 60%;
        @media (max-width: 991px) {
            display: none;
        }
      }
    }
  }
  .container {
    z-index: 2;
    padding-top: 20%;
  }
}
  .floating-pods-slider {
    position: relative;
    display: flex;
    flex-wrap: nowrap;
    overflow: hidden;
    width: 100%;
  }
    .floating-pods .pods-container .pod {
        width: 21%;
    position: absolute;}
        .floating-pods .pods-container {
        position: absolute;
        height: 100%;
    }
  .floating-pods-slider .slider-wrapper {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    animation-name: scrolling-left;
    animation-iteration-count: infinite;
    animation-timing-function: linear;
    animation-duration: 25s;
    animation-play-state: running;
    gap: 2em;
    padding-right: 2em;
  }
  @media (min-width: 768px) {
    .floating-pods-slider:hover .slider-wrapper {
      animation-play-state: paused;
    }
  }
  @keyframes scrolling-left {
    0% {
      transform: translateZ(0);
      visibility: visible;
    }

    100% {
      transform: translate3d(-100%, 0, 0);
    }
  }


.section-testimonial-blog-v1{
padding: 0 !important;
}

.zindex2{
position: relative;
z-index: 2;
}

.buttbutton{
color: #e272a3;
margin: 15px;
}

.buttbutton:hover{
color: #E15F8D ;}

.row{
    justify-content: center;}
  
@media (max-width: 768px){
  .my-2{
    font-size: 24px;
  }
}


</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<script>
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', init_pods);
} else {
  init_pods();
}

function init_pods() {
  const pods = gsap.utils.toArray(".pod");
  const container = document.querySelector(".pods-container");
  if (!container) return;

  const centerX = container.offsetWidth / 2;
  const centerY = container.offsetHeight / 2;

  pods.forEach((pod, i) => {
    const rect = pod.getBoundingClientRect();
    const containerRect = container.getBoundingClientRect();

    // Calculate how far from center each pod’s CSS position is
    const podCenterX = rect.left - containerRect.left + rect.width / 2;
    const podCenterY = rect.top - containerRect.top + rect.height / 2;
    const fromX = centerX - podCenterX;
    const fromY = centerY - podCenterY;

    // Animate from center to its natural CSS position
    gsap.from(pod, {
      x: fromX,
      y: fromY,
      scale: 0.6,
      rotation: (i % 2 === 0 ? -15 : 15),
      ease: "power2.out",
      scrollTrigger: {
        trigger: container,
        start: "top bottom",
        end: "top center",
        scrub: 5,
        markers: false,
      }
    });
  });
}
</script>




{% schema %}
{
  "name": "Slideshow Peek 2",
  "tag": "section",
  "class": "slideshow-peek-section",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image"
        },
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading",
          "default": "Slide heading"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Subheading",
          "default": "Slide subheading"
        },
        {
          "type": "header",
          "content": "Button Slideshow"
        },
        {
          "type": "text",
          "id": "block_button",
          "label": "Button Label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "block_url",
          "label": "URL Button",
          "default": "/collections/all"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "vertical_position",
          "label": "Vertical Position",
          "default": "bottom",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "bottom", "label": "Bottom" }
          ]
        },
        {
          "type": "select",
          "id": "horizontal_position",
          "label": "Horizontal Position",
          "default": "left",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ]
        },
        {
  "type": "range",
  "id": "heading_font_size_desktop",
  "label": "Heading Font Size (Desktop px)",
  "min": 12,
  "max": 60,
  "step": 1,
  "default": 32
},
{
  "type": "range",
  "id": "heading_font_size_mobile",
  "label": "Heading Font Size (Mobile px)",
  "min": 12,
  "max": 60,
  "step": 1,
  "default": 24
},
{
  "type": "range",
  "id": "subheading_font_size_desktop",
  "label": "Subheading Font Size (Desktop px)",
  "min": 10,
  "max": 40,
  "step": 1,
  "default": 18
},
{
  "type": "range",
  "id": "subheading_font_size_mobile",
  "label": "Subheading Font Size (Mobile px)",
  "min": 10,
  "max": 40,
  "step": 1,
  "default": 14
},
        {
  "type": "color",
  "id": "text-bg-color",
  "label": "Text Container Background Color",
  "default": "#f0f0f0"
},
              {
  "type": "color",
  "id": "color_block_button",
  "label": "Button Font Color",
  "default": "#ffffff"
},
{
  "type": "color",
  "id": "bg_color_block_button",
  "label": "Button Background Color",
  "default": "#E15F8D"
},
{
  "type": "color",
  "id": "color_hover_text",
  "label": "Button Hover Font Color",
  "default": "#ffffff"
},
{
  "type": "color",
  "id": "bg_color_hover_button",
  "label": "Button Hover Background Color",
  "default": "#000000"
}


      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Slideshow Peek 2",
      "category": "Image",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}

<div class="slides-container-wrapper">
  <button class="slide-nav prev" aria-label="Previous Slide">
    <i class="fa-solid fa-arrow-left"></i>
  </button>
  <div class="slides-container">
    {% for block in section.blocks %}
      <div class="slide">
        {% if block.settings.desktop_image != blank %}
          <img 
            class="slide-image desktop-only aspect69" 
            src="{{ block.settings.desktop_image | image_url: width: 1600 }}" 
            alt="" 
            loading="lazy"
          >
        {% endif %}
        {% if block.settings.mobile_image != blank %}
          <img 
            class="slide-image mobile-only aspect69" 
            src="{{ block.settings.mobile_image | image_url: width: 1000 }}" 
            alt="" 
            loading="lazy"
          >
        {% endif %}

        <div class="slide-text-container" style="background-color: {{ block.settings.text-bg-color }}">
          <div class="slide-text-inner pos-{{ block.settings.vertical_position }}-{{ block.settings.horizontal_position }}">
            <h2 class="title69 responsive-heading-{{ block.id }}">
              {{ block.settings.heading }}
            </h2>
            <p class="fonterr responsive-subheading-{{ block.id }}">
              {{ block.settings.subheading }}
            </p>
            {% if block.settings.block_button != blank %}
              <div class="btn-animation-{{ block.id }} animated">
                <a class="button-universal2 button-shop-{{ block.id }}"
   href="{{ block.settings.block_url }}"
   >
  {{ block.settings.block_button }}
</a>


              </div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
  <button class="slide-nav next" aria-label="Next Slide">
    <i class="fa-solid fa-arrow-right"></i>
  </button>
</div>



<style>
{% for block in section.blocks %}
  .responsive-heading-{{ block.id }} {
    font-size: {{ block.settings.heading_font_size_desktop | default: 32 }}px;
  }
  .responsive-subheading-{{ block.id }} {
    font-size: {{ block.settings.subheading_font_size_desktop | default: 18 }}px;
  }

  @media (max-width: 768px) {
    .responsive-heading-{{ block.id }} {
      font-size: {{ block.settings.heading_font_size_mobile | default: 24 }}px;
    }
    .responsive-subheading-{{ block.id }} {
      font-size: {{ block.settings.subheading_font_size_mobile | default: 14 }}px;
    }
  }

.button-shop-{{block.id}}{
    background: linear-gradient(to right,{{block.settings.bg_color_hover_button}} 50%,{{block.settings.bg_color_block_button}} 50%) no-repeat scroll right bottom/210% 100% {{block.settings.bg_color_block_button}};
    color : {{block.settings.color_block_button}};
  }
 .button-shop-{{block.id}}:hover{
    color : {{block.settings.color_hover_text}};
  }
{% endfor %}

   .fonterr{
    font-family: nunito;
  }
  
.slides-container-wrapper {
  position: relative;
  width: 100%;
  overflow: hidden;
}

.slides-container {
  display: flex;
  overflow-x: auto;
  scroll-behavior: smooth;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  gap: 2px;
}

.slide {
  flex: 0 0 75%;
  scroll-snap-align: start;
  border-radius: 4px;
  overflow: hidden;
  background: #fff;
  display: flex;
  flex-direction: column;
  aspect-ratio: auto; /* disable fixed aspect ratio */
}

@media (min-width: 768px) {
  .aspect69 {
    aspect-ratio: 18 / 7;
  }
} 


@media (max-width: 767px){
    .aspect69{
      aspect-ratio: 1 / 1;
    }
    
  }
  

@media (max-width: 768px) {
  .slide {
    flex: 0 0 85%;
  }
}

.slide-image {
  width: 100%;
  height: auto;
  object-fit: cover;
  display: block;
}

.slide-text-container {
  padding: 2rem 1rem;
  text-align: center;
}

.slide-text-inner {
  max-width: 800px;
  margin: 0 auto;
  color: #000;
}

.slide-nav {
  position: absolute;
  bottom: calc(50%); /* aligns between image and text */
  transform: translateY(50%);
  background: white;
  color: black;
  border: none;
  z-index: 8;
  width: 30px;
  height: 30px;
  cursor: pointer;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  padding: 0; /* remove extra spacing */
  box-shadow: 1px 2px 6px 4px rgba(53, 57, 68, .5);
  font-weight: bold;
}

  .slide-nav:hover{
    background: #e272a3;
  }

.slide-nav.prev {
  left: 1rem;
}
.slide-nav.next {
  right: 3rem;
}

@media (max-width: 599px) {
  .desktop-only {
    display: none !important;
  }
  .mobile-only {
    display: block !important;
  }
}

@media (min-width: 600px) {
  .desktop-only {
    display: block !important;
  }
  .mobile-only {
    display: none !important;
  }
}

.slide-nav.hidden {
  opacity: 0;
  pointer-events: none;
}

</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const wrapper = document.querySelector('.slides-container-wrapper');
  const container = wrapper?.querySelector('.slides-container');
  const nextBtn = wrapper?.querySelector('.slide-nav.next');
  const prevBtn = wrapper?.querySelector('.slide-nav.prev');

nextBtn?.addEventListener('click', () => {
  const slides = container.querySelectorAll('.slide');
  const current = container.scrollLeft;

  // Find the next slide based on current scroll position
  let target = null;
  for (let i = 0; i < slides.length; i++) {
    if (slides[i].offsetLeft > current + 5) {
      target = slides[i].offsetLeft;
      break;
    }
  }

  // If no next slide, do nothing
  if (target !== null) {
    container.scrollTo({ left: target, behavior: 'smooth' });
  }
});

prevBtn?.addEventListener('click', () => {
  const slides = container.querySelectorAll('.slide');
  const current = container.scrollLeft;

  // Find the previous slide
  let target = null;
  for (let i = slides.length - 1; i >= 0; i--) {
    if (slides[i].offsetLeft < current - 5) {
      target = slides[i].offsetLeft;
      break;
    }
  }

  if (target !== null) {
    container.scrollTo({ left: target, behavior: 'smooth' });
  }
});

  function updateNavVisibility() {
    const maxScroll = container.scrollWidth - container.clientWidth;

    if (container.scrollLeft <= 5) {
      prevBtn.classList.add("hidden");
    } else {
      prevBtn.classList.remove("hidden");
    }

    if (container.scrollLeft >= maxScroll - 5) {
      nextBtn.classList.add("hidden");
    } else {
      nextBtn.classList.remove("hidden");
    }
  }

  nextBtn?.addEventListener('click', () => {
    container?.scrollBy({ left: getSlideWidth(), behavior: 'smooth' });
    setTimeout(updateNavVisibility, 300);
  });

  prevBtn?.addEventListener('click', () => {
    container?.scrollBy({ left: -getSlideWidth(), behavior: 'smooth' });
    setTimeout(updateNavVisibility, 300);
  });

  container?.addEventListener("scroll", updateNavVisibility);

  updateNavVisibility(); // initial check
});


document.addEventListener("DOMContentLoaded", function () {
  const textContainers = document.querySelectorAll('.slide-text-container');

  let maxHeight = 0;

  textContainers.forEach(container => {
    container.style.height = 'auto'; // Reset height first in case of resize
    const height = container.offsetHeight;
    if (height > maxHeight) {
      maxHeight = height;
    }
  });

  textContainers.forEach(container => {
    container.style.height = `${maxHeight}px`;
  });
});

  window.addEventListener('resize', () => {
  const textContainers = document.querySelectorAll('.slide-text-container');

  let maxHeight = 0;

  textContainers.forEach(container => {
    container.style.height = 'auto';
    const height = container.offsetHeight;
    if (height > maxHeight) {
      maxHeight = height;
    }
  });

  textContainers.forEach(container => {
    container.style.height = `${maxHeight}px`;
  });
});

</script>


{% comment %}
  Image Slider Section
  Horizontal scrolling image slider with square images, optional overlay, and text support.
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    --slider-gap: {{ section.settings.image_gap }}px;
    --overlay-opacity: {% if section.settings.show_overlay %}{{ section.settings.overlay_opacity | divided_by: 100.0 }}{% else %}0{% endif %};
    --overlay-color: {{ section.settings.overlay_color }};
    --text-color: {{ section.settings.text_color }};
    --cols-desktop: {{ section.settings.images_per_row_desktop }};
    --cols-tablet: {{ section.settings.images_per_row_tablet }};
    --cols-mobile: {{ section.settings.images_per_row_mobile }};
  }

  .img-slider-section {
    padding: {{ section.settings.section_padding_vertical }}px {{ section.settings.section_padding_horizontal }}px;
    background-color: {{ section.settings.background_color }};
    overflow: hidden;
  }

  .img-slider-heading {
    margin: 0 0 16px 0;
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_color }};
    text-align: {{ section.settings.heading_alignment }};
  }

  .img-slider-subheading {
    margin: -8px 0 20px 0;
    font-size: {{ section.settings.subheading_size }}px;
    color: {{ section.settings.subheading_color }};
    text-align: {{ section.settings.heading_alignment }};
  }

  .img-slider-track-wrapper {
    position: relative;
  }

  /* Arrow buttons */
  .img-slider-arrow {
    display: {% if section.settings.show_arrows %}flex{% else %}none{% endif %};
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid {{ section.settings.arrow_color }};
    background: {{ section.settings.arrow_bg }};
    color: {{ section.settings.arrow_color }};
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: opacity 0.2s ease, background 0.2s ease;
    padding: 0;
  }

  .img-slider-arrow:hover {
    opacity: 0.8;
  }

  .img-slider-arrow.prev { left: -20px; }
  .img-slider-arrow.next { right: -20px; }

  .img-slider-arrow.hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* Scrollable track */
  .img-slider-track {
    display: flex;
    gap: var(--slider-gap);
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: {% if section.settings.show_scrollbar %}thin{% else %}none{% endif %};
    -ms-overflow-style: {% if section.settings.show_scrollbar %}auto{% else %}none{% endif %};
    padding-bottom: 4px;
  }

  .img-slider-track::-webkit-scrollbar {
    height: {% if section.settings.show_scrollbar %}6px{% else %}0{% endif %};
  }

  .img-slider-track::-webkit-scrollbar-track {
    background: rgba(0,0,0,0.1);
    border-radius: 3px;
  }

  .img-slider-track::-webkit-scrollbar-thumb {
    background: {{ section.settings.arrow_color }};
    border-radius: 3px;
  }

  /* Each slide item */
  .img-slider-item {
    flex: 0 0 calc((100% - (var(--cols-desktop) - 1) * var(--slider-gap)) / var(--cols-desktop));
    min-width: 0;
    position: relative;
    border-radius: {{ section.settings.image_border_radius }}px;
    overflow: hidden;
  }

  /* Force square aspect ratio */
  .img-slider-item-inner {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  .img-slider-item-inner img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  {% if section.settings.zoom_on_hover %}
  .img-slider-item:hover .img-slider-item-inner img {
    transform: scale(1.06);
  }
  {% endif %}

  /* Overlay */
  .img-slider-overlay {
    position: absolute;
    inset: 0;
    background-color: var(--overlay-color);
    opacity: var(--overlay-opacity);
    pointer-events: none;
    transition: opacity 0.3s ease;
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  /* Text content on image */
  .img-slider-text {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: {{ section.settings.text_vertical_position }};
    align-items: {{ section.settings.text_horizontal_position }};
    padding: 12px;
    color: var(--text-color);
    text-align: center;
    z-index: 2;
  }

  .img-slider-text .slide-label {
    font-size: clamp(10px, 1.8vw, {{ section.settings.label_font_size }}px);
    font-weight: {{ section.settings.label_font_weight }};
    line-height: 1.3;
    margin: 0;
    text-shadow: 0 1px 3px rgba(0,0,0,0.5);
    word-break: break-word;
  }

  .img-slider-text .slide-sublabel {
    font-size: clamp(9px, 1.2vw, {{ section.settings.sublabel_font_size }}px);
    font-weight: 400;
    margin: 4px 0 0 0;
    opacity: 0.85;
    text-shadow: 0 1px 3px rgba(0,0,0,0.5);
    word-break: break-word;
  }

  /* CTA link wrapper */
  .img-slider-item a {
    text-decoration: none;
    display: block;
  }

  /* Tablet */
  @media screen and (max-width: 1023px) {
    .img-slider-item {
      flex: 0 0 calc((100% - (var(--cols-tablet) - 1) * var(--slider-gap)) / var(--cols-tablet));
    }

    .img-slider-text .slide-label {
      font-size: clamp(10px, 2.5vw, {{ section.settings.label_font_size }}px);
    }
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    .img-slider-item {
      flex: 0 0 calc((100% - (var(--cols-mobile) - 1) * var(--slider-gap)) / var(--cols-mobile));
    }

    .img-slider-arrow {
      width: 32px;
      height: 32px;
    }

    .img-slider-arrow.prev { left: -16px; }
    .img-slider-arrow.next { right: -16px; }

    .img-slider-text .slide-label {
      font-size: clamp(10px, 3.5vw, {{ section.settings.label_font_size }}px);
    }

    .img-slider-text .slide-sublabel {
      font-size: clamp(8px, 2.5vw, {{ section.settings.sublabel_font_size }}px);
    }
  }
</style>

<section class="img-slider-section" data-section-id="{{ section.id }}">

  {% if section.settings.heading != blank %}
    <h2 class="img-slider-heading">{{ section.settings.heading }}</h2>
  {% endif %}

  {% if section.settings.subheading != blank %}
    <p class="img-slider-subheading">{{ section.settings.subheading }}</p>
  {% endif %}

  <div class="img-slider-track-wrapper">

    {% if section.settings.show_arrows %}
      <button class="img-slider-arrow prev" aria-label="Previous" data-dir="-1">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="img-slider-arrow next" aria-label="Next" data-dir="1">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    <div class="img-slider-track" id="sliderTrack-{{ section.id }}">

      {% for block in section.blocks %}
        {% if block.type == 'slide' %}
          <div class="img-slider-item" {{ block.shopify_attributes }}>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}">
            {% endif %}

            <div class="img-slider-item-inner">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 600 | image_tag:
                  loading: 'lazy',
                  widths: '200, 300, 400, 600',
                  alt: block.settings.image.alt | default: block.settings.label
                }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}

              <div class="img-slider-overlay"></div>

              {% if block.settings.label != blank or block.settings.sublabel != blank %}
                <div class="img-slider-text">
                  {% if block.settings.label != blank %}
                    <p class="slide-label">{{ block.settings.label }}</p>
                  {% endif %}
                  {% if block.settings.sublabel != blank %}
                    <p class="slide-sublabel">{{ block.settings.sublabel }}</p>
                  {% endif %}
                </div>
              {% endif %}
            </div>

            {% if block.settings.link != blank %}
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

    </div>
  </div>
</section>

<script>
  (function() {
    var section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    var track = section.querySelector('#sliderTrack-{{ section.id }}');
    var prevBtn = section.querySelector('.img-slider-arrow.prev');
    var nextBtn = section.querySelector('.img-slider-arrow.next');

    if (!track) return;

    function getScrollAmount() {
      var item = track.querySelector('.img-slider-item');
      if (!item) return track.clientWidth * 0.8;
      var gap = parseInt(getComputedStyle(track).gap) || 0;
      return item.offsetWidth + gap;
    }

    function updateArrows() {
      if (!prevBtn || !nextBtn) return;
      prevBtn.classList.toggle('hidden', track.scrollLeft <= 2);
      nextBtn.classList.toggle('hidden', track.scrollLeft + track.clientWidth >= track.scrollWidth - 2);
    }

    if (prevBtn && nextBtn) {
      prevBtn.addEventListener('click', function() {
        track.scrollBy({ left: -getScrollAmount() * 2, behavior: 'smooth' });
      });
      nextBtn.addEventListener('click', function() {
        track.scrollBy({ left: getScrollAmount() * 2, behavior: 'smooth' });
      });
      track.addEventListener('scroll', updateArrows, { passive: true });
      updateArrows();
    }
  })();
</script>

{% schema %}
{
  "name": "Service v3",
  "tag": "section",
  "class": "image-slider-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Collection"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading Font Size (px)",
      "min": 12,
      "max": 30,
      "step": 1,
      "default": 16
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#555555"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "images_per_row_desktop",
      "label": "Images Visible – Desktop",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 5,
      "info": "How many images fit side by side on large screens (≥1024px)"
    },
    {
      "type": "range",
      "id": "images_per_row_tablet",
      "label": "Images Visible – Tablet",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "info": "How many images fit side by side on tablet screens (750–1023px)"
    },
    {
      "type": "range",
      "id": "images_per_row_mobile",
      "label": "Images Visible – Mobile",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "info": "How many images fit side by side on mobile screens (<750px)"
    },
    {
      "type": "range",
      "id": "image_gap",
      "label": "Gap Between Images (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image Corner Radius (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 8
    },
    {
      "type": "range",
      "id": "section_padding_vertical",
      "label": "Section Padding – Top & Bottom (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "label": "Section Padding – Left & Right (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 20
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Image Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show Overlay",
      "default": true,
      "info": "Toggle a colour overlay on all images"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity (%)",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 30
    },
    {
      "type": "header",
      "content": "Text on Images"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "label_font_size",
      "label": "Label Max Font Size (px)",
      "min": 10,
      "max": 36,
      "step": 1,
      "default": 16,
      "info": "Scales down automatically for smaller images"
    },
    {
      "type": "range",
      "id": "label_font_weight",
      "label": "Label Font Weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 600
    },
    {
      "type": "range",
      "id": "sublabel_font_size",
      "label": "Sub-label Max Font Size (px)",
      "min": 8,
      "max": 24,
      "step": 1,
      "default": 12
    },
    {
      "type": "select",
      "id": "text_vertical_position",
      "label": "Text Vertical Position",
      "default": "flex-end",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Middle" },
        { "value": "flex-end", "label": "Bottom" }
      ]
    },
    {
      "type": "select",
      "id": "text_horizontal_position",
      "label": "Text Horizontal Alignment",
      "default": "center",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrow Buttons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_scrollbar",
      "label": "Show Scrollbar",
      "default": false
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow Icon & Border Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "arrow_bg",
      "label": "Arrow Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Interaction"
    },
    {
      "type": "checkbox",
      "id": "zoom_on_hover",
      "label": "Zoom Image on Hover",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category Name"
        },
        {
          "type": "text",
          "id": "sublabel",
          "label": "Sub-label / Description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service v3",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}

<div data-section-id="{{ section.id }}" data-section-type="section-service-v1" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{%endif%} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %} {% if section.settings.sections_layout == "dark" %}background: {{section.settings.sections_bg_color}};{% endif %}">
  <div class="container container-v2">
    <div class="section-service-v1">
      <div class="row js-service-v1">
        {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
        {% if block.type == "service" %}
        <div class="text-center itemtservice justify-content-center col-12">
          <div class="box-service">
           <div class="icon">
					{% if block.settings.block_icon_svg != blank %}{{block.settings.block_icon_svg}}{% endif %}
                    </div>

            <div class="info">
              {% if block.settings.block_title != blank %}
              <h4 class="title">{{block.settings.block_title}}</h4>
              {% endif %}
              {% if block.settings.block_content != blank %}          	
              <p class="content">{{block.settings.block_content}}</p>
              {% endif %}
            </div>
          </div>
        </div>
        {% endif %}
        {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "SERVICE V1.5",
  "class": "index-section",
  "settings": [ 
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Background image Section"
    },
    {
      "type": "header",
      "content": "Section Space"
    },
    {
      "type": "text",
      "id": "margin_top",
      "label": "Margin Top",
      "info": "Defined in pixels. Do not add the 'px' unit."
    },
    {
      "type": "text",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "info": "Defined in pixels. Do not add the 'px' unit."
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service V1.5",
      "settings": [{
          "type": "textarea",
          "id": "block_icon_svg",
          "label": "Icon Svg"
        },
        {
          "type": "text",
          "id": "block_number",
          "label": "Number",
          "default": "1"
        },
        {
          "type": "image_picker",
          "id": "img_icon",
          "label": "Image icon"
        },
        {
          "type": "text",
          "id": "block_title",
          "label": "Title",
          "default": "FREE SHIPPING"
        },
        {
          "type": "text",
          "id": "block_content",
          "label": "Content",
          "default": "Across West & East from Handpicked Sellers"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SERVICE V1.5",
      "category": "HOME",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "block_number": "1",
            "block_title": "FREE SHIPPING",
            "block_content": "Across West & East from Handpicked Sellers"
          }
        },
        {
          "type": "service",
          "settings": {
            "block_number": "2",
            "block_title": "100% Natural",
            "block_content": "Eat local, consume local, closer to nature."
          }
        },
        {
          "type": "service",
          "settings": {
            "block_number": "3",
            "block_title": "Handmade",
            "block_content": "Made with passion by 300+ curators across."
          }
        },
        {
          "type": "service",
          "settings": {
            "block_number": "4",
            "block_title": "Curated Products",
            "block_content": "Eat local, consume local, closer to nature."
          }
        }
      ]
    }
  ]
}
{% endschema %}


{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}

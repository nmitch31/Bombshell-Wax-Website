<div data-section-id="{{ section.id }}" data-section-type="section-collection-v3" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{%endif%} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %} {% if section.settings.sections_layout == "dark" %}background: {{section.settings.sections_bg_color}};{% endif %}">
  <div class="section-collection-v3">
    <div class="container container-v2">
      
      
      <div class="pd-small" style="background: {{section.settings.bg_section}}">
    <div class="container container-v2">
      <div class="col-12 col-md-10 col-lg-8 px-0 mx-auto text-center">

        {% if section.settings.title_heading != blank %}
        <h3 class="title_heading mb-0 animate-on-scroll"
   data-effect="{{ section.settings.effect_heading }}"
   data-delay="{{ section.settings.effect_delay_heading }}"
   data-duration="{{ section.settings.effect_duration_heading }}" style="color: {{section.settings.color_title}}">{{section.settings.title_heading}}</h3>
        {% endif %}

        {% if section.settings.sub_heading != blank %}
        <p class="sub_heading animate-on-scroll"
   data-effect="{{ section.settings.effect_sub_heading }}"
   data-delay="{{ section.settings.effect_delay_sub_heading }}"
   data-duration="{{ section.settings.effect_duration_sub_heading }}" style="color: {{section.settings.color_sub_heading}}">{{section.settings.sub_heading}}</p>
        {% endif %}

      </div>
    </div>
      </div>
{% comment %}
  <div>
    <img src="https://cdn.shopify.com/s/files/1/0347/0934/0300/files/single_rose_garden_bead_upscaled.png?v=1758814008" alt="Rose Garden Bead" width="85" height="85" class="rotating bead1">
      </div>  
      <div>
    <img src="https://cdn.shopify.com/s/files/1/0347/0934/0300/files/single_rose_garden_bead_upscaled.png?v=1758814008" alt="Rose Garden Bead" width="85" height="85" class="rotating bead2">
  </div> 
{% endcomment %}
      <div class="row js-collection-v3">
        {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
        {% if block.type == 'colection' %}
        <div class="col-lg-4 col-md-4 col-sm-6 col-12 col-item">
          <div class="item">
            <div class="box-img">
              <a href="{{block.settings.brand_url}}" title="{{block.settings.title_collection}}">
                {% if block.settings.brand_img != blank %}
                <img data-src="{{block.settings.brand_img | img_url:'master'}}" class="lazyload img-fluid w-100" alt="_img_collection">
                {% else %}
                <img data-src="//via.placeholder.com/456x456" class="lazyload img-fluid w-100" alt="_img_collection">
                {% endif %}
              </a>
            </div>
            <div class="category-info">
              <div class="box-info">
                {% if block.settings.title_collection != blank %}
                <a href="{{block.settings.brand_url}}" class="title-collection">{{block.settings.title_collection}}</a>
                {% endif %}
                {% if block.settings.block_content != blank %}
                <p class="content-box mb-0">{{block.settings.block_content}}</p>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
        {% endif %}
        {% endfor %}
        {% endif %} 
      </div>
    </div>
  </div>
</div>
{% schema %}
{

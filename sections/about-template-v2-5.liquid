<section class="page_aboutus_v1 page_aboutus_v2">

  {% if section.settings.enable_teams %}
  <div class="teams">
    <div class="container">
      <div class="text-center title_general">
        {% if section.settings.title_teams != blank %}
        <h3>
          {{section.settings.title_teams}}
        </h3>
        {% endif %}
        {% if section.settings.description_teams != blank %}
        <p>{{section.settings.description_teams}}</p>
        {% endif %}
      </div>
      <div class="row">
        <div class="col-lg-12">
          <div class="slick_teams">
            {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
            {% if block.type == "teams" %}
            <div class="box_teams text-center">
              <div class="img_teams">

                <a href="{{block.settings.link_people_teams}}" title="">
                  {% if block.settings.people_teams_image != blank %}
                  <img src="{{block.settings.people_teams_image|img_url:'master'}}" class="img-fluid" alt="banner">
                  {% else %}
                  <img src="//via.placeholder.com/300x370" alt="" class="img-fluid">
                  {%  endif %}
                </a>
              </div>
              <div class="info_teams">
                <h4 class="text-uppercase">
                  {% if block.settings.block_people_teams != blank %}
                  <a href="{{block.settings.link_people_teams}}" title="">{{block.settings.block_people_teams}}</a>
                  {% endif %}
                </h4>
                {% if block.settings.block_position_teams != blank %}
                <p class="mb-0">{{block.settings.block_position_teams}}</p>
                {% endif %}
              </div>
            </div>
            {% endif %}
            {% endfor %}
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

{% if section.settings.enable_address %}
  <div class="address">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <div class="address_pagev2  d-flex justify-content-between">

            {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
            {% if block.type == "address" %}

            <div class="newyork">
              {% if block.settings.block_title_address != blank %}
              <h5 class="title_address_page">{{block.settings.block_title_address}}</h5>
              {% endif %}
              {% if block.settings.block_p_address != blank %}
              <p>{{ block.settings.block_p_address}}</p>
              {% endif %}
              {% if block.settings.block_time_address != blank %}
              <p>{{ block.settings.block_time_address}}</p>
              {% endif %}
              {% if block.settings.block_email_address != blank %}
              <p class="mbend">{{block.settings.block_email_address}}</p>
              {% endif %}
            </div>

            {% endif %}
            {% endfor %}
            {% endif %}

          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}
  
  {% if section.settings.enable_video %}
  <div class="video">
    <div class="container">
      <div class="row text-center">
        <div class="col-lg-12">        
          <div class= "box-video"> 
            <a data-fancybox href="{{ section.settings.url_section_video }} ">              
              {% if section.settings.image_video != blank %}
              <img src="{{section.settings.image_video|img_url:'master'}}" class="img-fluid" alt="">
              {% else %}
              <img src="//via.placeholder.com/1170x500" class="img-fluid" alt="">
              {% endif %}
              <i class="fa fa-play"></i>
            </a>            
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}
</section>

<script>
  jQuery(document).ready(function($) {

    $('.slick_teams').slick({
      dots: false,
      arrows:false,
      infinite: true,
      speed: 300,
      slidesToShow: 3,
      slidesToScroll: 1,
      autoplay: true,
      autoplaySpeed: 3000,
      {% if settings.enable_rtl_mode %}rtl: true,{% endif %}
      responsive: [
        {
          breakpoint: 1024,
          settings: {
            slidesToShow: 2,
            slidesToScroll: 2,
            infinite: true,
            dots: false,
            arrows:false
          }
        },
        {
          breakpoint: 600,
          settings: {
            slidesToShow: 1,
            slidesToScroll: 1,
            dots: false,
            arrows:false
          }
        },
        {
          breakpoint: 480,
          settings: {
            slidesToShow: 1,
            slidesToScroll: 1,
            dots: false,
            arrows:false
          }
        }
      ]
    });
  })
</script>



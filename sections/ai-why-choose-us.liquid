{% doc %}
  @prompt
    A dynamic "Why choose our product" section for the homepage of the website. The sections should feature an image on the left half, and 4 squares on the right half, 2 rows of 2. Include creative design options like svg icons in each square and scroll into frame animations for the elements in the section. Ensure mobile responsiveness, with padding to the left and right edges of the screen. On mobile, from top to bottom the section should go header, subheader, 2 of the squares in a row, the image, then the other 2 squares of the row. Also utilize font family: nunito., make the icons manually inputted not predetermined. Add hover effects. Add scroll into frame effect options., remove the shake effect on the icons. Ensure the cursor stays default on hover effects.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-why-choose-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    font-family: 'Nunito', sans-serif;
  }

  .ai-why-choose-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
  }

  .ai-why-choose-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
    opacity: 0;
    transform: translateY(30px);
  }

  .ai-why-choose-header-{{ ai_gen_id }}.ai-animate-in-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ai-why-choose-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 700;
  }

  .ai-why-choose-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    font-weight: 400;
  }

  .ai-why-choose-content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }

  .ai-why-choose-features-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .ai-why-choose-feature-{{ ai_gen_id }} {
    background-color: {{ block.settings.feature_bg_color }};
    padding: 30px 24px;
    border-radius: {{ block.settings.feature_border_radius }}px;
    text-align: center;
    opacity: 0;
    cursor: default;
    {% if block.settings.animation_type == 'fade_up' %}
      transform: translateY(30px);
    {% elsif block.settings.animation_type == 'fade_down' %}
      transform: translateY(-30px);
    {% elsif block.settings.animation_type == 'fade_left' %}
      transform: translateX(-30px);
    {% elsif block.settings.animation_type == 'fade_right' %}
      transform: translateX(30px);
    {% elsif block.settings.animation_type == 'scale' %}
      transform: scale(0.8);
    {% elsif block.settings.animation_type == 'rotate' %}
      transform: rotate(-5deg) scale(0.9);
    {% endif %}
    transition: all 0.3s ease;
  }

  .ai-why-choose-feature-{{ ai_gen_id }}.ai-animate-in-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0) translateX(0) scale(1) rotate(0);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ai-why-choose-feature-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.feature_hover_bg_color }};
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }

  .ai-why-choose-feature-{{ ai_gen_id }}.ai-animate-in-{{ ai_gen_id }}:hover {
    transform: translateY(-8px) scale(1.02);
  }

  .ai-why-choose-feature-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .ai-why-choose-feature-{{ ai_gen_id }}:hover .ai-why-choose-feature-icon-{{ ai_gen_id }} {
    transform: scale(1.1);
  }

  .ai-why-choose-feature-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
    transition: fill 0.3s ease;
  }

  .ai-why-choose-feature-{{ ai_gen_id }}:hover .ai-why-choose-feature-icon-{{ ai_gen_id }} svg {
    fill: {{ block.settings.icon_hover_color }};
  }

  .ai-why-choose-feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_title_size }}px;
    color: {{ block.settings.feature_title_color }};
    margin: 0 0 8px;
    font-weight: 700;
    transition: color 0.3s ease;
  }

  .ai-why-choose-feature-{{ ai_gen_id }}:hover .ai-why-choose-feature-title-{{ ai_gen_id }} {
    color: {{ block.settings.feature_title_hover_color }};
  }

  .ai-why-choose-feature-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_description_size }}px;
    color: {{ block.settings.feature_description_color }};
    margin: 0;
    line-height: 1.6;
    transition: color 0.3s ease;
  }

  .ai-why-choose-feature-{{ ai_gen_id }}:hover .ai-why-choose-feature-description-{{ ai_gen_id }} {
    color: {{ block.settings.feature_description_hover_color }};
  }

  .ai-why-choose-image-wrapper-{{ ai_gen_id }} {
    opacity: 0;
    cursor: default;
    {% if block.settings.image_animation_type == 'fade_left' %}
      transform: translateX(-30px);
    {% elsif block.settings.image_animation_type == 'fade_right' %}
      transform: translateX(30px);
    {% elsif block.settings.image_animation_type == 'fade_up' %}
      transform: translateY(30px);
    {% elsif block.settings.image_animation_type == 'fade_down' %}
      transform: translateY(-30px);
    {% elsif block.settings.image_animation_type == 'scale' %}
      transform: scale(0.8);
    {% elsif block.settings.image_animation_type == 'rotate' %}
      transform: rotate(-5deg) scale(0.9);
    {% endif %}
    transition: transform 0.3s ease;
  }

  .ai-why-choose-image-wrapper-{{ ai_gen_id }}.ai-animate-in-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateX(0) translateY(0) scale(1) rotate(0);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ai-why-choose-image-wrapper-{{ ai_gen_id }}:hover {
    transform: scale(1.02);
  }

  .ai-why-choose-image-wrapper-{{ ai_gen_id }}.ai-animate-in-{{ ai_gen_id }}:hover {
    transform: scale(1.02);
  }

  .ai-why-choose-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: block;
    transition: transform 0.3s ease;
  }

  .ai-why-choose-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-why-choose-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-why-choose-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 768px) {
    .ai-why-choose-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-why-choose-content-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .ai-why-choose-features-{{ ai_gen_id }} {
      order: 1;
    }

    .ai-why-choose-image-wrapper-{{ ai_gen_id }} {
      order: 2;
    }

    .ai-why-choose-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-why-choose-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }

    .ai-why-choose-feature-{{ ai_gen_id }} {
      padding: 24px 20px;
    }
  }
{% endstyle %}

<why-choose-section-{{ ai_gen_id }} class="ai-why-choose-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-why-choose-container-{{ ai_gen_id }}">
    <div class="ai-why-choose-header-{{ ai_gen_id }}" data-animate>
      {% if block.settings.heading != blank %}
        <h2 class="ai-why-choose-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-why-choose-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="ai-why-choose-content-{{ ai_gen_id }}">
      <div class="ai-why-choose-image-wrapper-{{ ai_gen_id }}" data-animate>
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1000 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-why-choose-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-why-choose-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-why-choose-empty-state-{{ ai_gen_id }}">
              Next, add an image
            </div>
          </div>
        {% endif %}
      </div>

      <div class="ai-why-choose-features-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          {% liquid
            assign feature_title_key = 'feature_' | append: i | append: '_title'
            assign feature_description_key = 'feature_' | append: i | append: '_description'
            assign feature_icon_key = 'feature_' | append: i | append: '_icon_svg'
            
            assign feature_title = block.settings[feature_title_key]
            assign feature_description = block.settings[feature_description_key]
            assign feature_icon = block.settings[feature_icon_key]
          %}
          
          <div class="ai-why-choose-feature-{{ ai_gen_id }}" data-animate style="transition-delay: {{ i | times: 0.1 }}s;">
            <div class="ai-why-choose-feature-icon-{{ ai_gen_id }}">
              {% if feature_icon != blank %}
                {{ feature_icon }}
              {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              {% endif %}
            </div>
            {% if feature_title != blank %}
              <h3 class="ai-why-choose-feature-title-{{ ai_gen_id }}">{{ feature_title }}</h3>
            {% endif %}
            {% if feature_description != blank %}
              <p class="ai-why-choose-feature-description-{{ ai_gen_id }}">{{ feature_description }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</why-choose-section-{{ ai_gen_id }}>

<script>
  (function() {
    class WhyChooseSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.animatedElements = [];
      }

      connectedCallback() {
        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const elements = this.querySelectorAll('[data-animate]');
        
        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !this.animatedElements.includes(entry.target)) {
              entry.target.classList.add('ai-animate-in-{{ ai_gen_id }}');
              this.animatedElements.push(entry.target);
            }
          });
        }, observerOptions);

        elements.forEach((element) => {
          observer.observe(element);
        });
      }
    }

    customElements.define('why-choose-section-{{ ai_gen_id }}', WhyChooseSection{{ ai_gen_id }});
  })();
</script>


<div data-section-id="{{ section.id }}" data-section-type="section-video-countdown-v1" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{%endif%} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %} {% if section.settings.sections_layout == "dark" %}background: {{section.settings.sections_bg_color}};{% endif %}">
  <div class="section-video-countdown-v2" style="background-image: url({% if section.settings.background-img != blank %}{{section.settings.background-img|img_url:'master'}}{% else %}//via.placeholder.com/1920x700{% endif %})">
    <div class="container container-v2">
      <div class="row align-items-center justify-content-center">
        <div class="col-lg-6 col-sm-6 col-md-6">
                       
            <div class="box-video relative">
              {% if section.settings.video_bg != blank %}
              <img src="{{section.settings.video_bg|img_url:'master'}}" class="img-fluid w-100" alt="Image">
              {% else %}
              <img src="//via.placeholder.com/800x500" class="img-fluid">
              {% endif %}
            </div>
         
        </div>
        <div class="col-lg-5 col-sm-6 col-md-6">
          <div class="content-countdown">
            {% if section.settings.title_countdown != blank %}
            <h3 class="title">                
              {{section.settings.title_countdown}}
            </h3>
            {% endif %}

            <div class="time">
              {% if section.settings.block_content != blank %}          	
              <p class="content">{{section.settings.block_content}}</p>
              {% endif %}
            </div>

            {% if section.settings.button_countdown != blank %}
            <a href="{{section.settings.url_button}}" class="button-main1">{{section.settings.button_countdown}}</a>
            {% endif %}

          </div>
        </div>
        
      </div>
    </div>
  </div>
</div>

<style>
  .section-video-countdown-v2 .button-main1 {
    background: {{section.settings.bg_color_button}};
    color: {{section.settings.color_button}};
  }
  .section-video-countdown-v2 .button-main1:hover {
    background: {{section.settings.bg_color_button_hover}};
    color: {{section.settings.color_button_hover}};
  }
  .section-video-countdown-v2 .content-countdown .title_heading {
    color: {{section.settings.color_title}};
  }
  .section-video-countdown-v2 .content-countdown .time ul li span {
    color: {{section.settings.color_title}};
  }
</style>
{% schema %}
{
  "name": "VIDEO COUNTDOWN V2",
  "class": "index-section",
  "settings": [
    {
          "type": "textarea",
          "id": "block_content",
          "label": "Content",
          "default": " If your glasses aren't perfect, return them within 30 days<br> for a full refund. We'll even pay shipping."
        },
    {
      "type": "header",
      "content": "Background Video"
    },
	{
      "type": "image_picker",
      "id": "background-img",
      "info": "1920 x 700px recommended",
      "label": "Background Image"
    },
    {
      "type": "header",
      "content": "Video"
    },
	{
      "type": "image_picker",
      "id": "video_bg",
      "info": "800 x 500px recommended",
      "label": "Image video"
    },
    {
      "type": "url",
      "id": "section_video_url",
      "label": "URL Video",
      "info": "[Upload video .mp4 in here](/admin/settings/files)"
    },
	{
      "type": "header",
      "content": "Countdown"
    },
	{
      "type": "text",
      "id": "title_countdown",
      "label": "Title",
      "default": "VIKINGS-INSPRIED WATCHES"
    },
	{
      "type": "color",
      "id": "color_title",
      "label": "Color Title",
      "default": "#fff"
    },
	{
      "type": "header",
      "content": "Setting Time"
    },
    {
      "type": "text",
      "id": "button_countdown",
      "label": "Button Countdow",
      "default": "Shop now"
    },
  	{
      "type": "url",
      "id": "url_button",
      "label": "URL button",
      "default": "/collections/all"
    },
        {
          "type": "color",
          "id": "bg_color_button",
          "label": "Background Color Button",
          "default": "#fff"
        },
        {
          "type": "color",
          "id": "color_button",
          "label": "Color button",
          "default": "#000"
        },
        {
          "type": "color",
          "id": "bg_color_button_hover",
          "label": "Background Hover Color",
          "default": "#fb5b21 "
        },
        {
          "type": "color",
          "id": "color_button_hover",
          "label": "Text Hover Color",
          "default": "#fff"
        },

    {
      "type": "header",
      "content": "Section Space"
    },
    {
      "type": "text",
      "id": "margin_top",
      "label": "Margin Top",
      "info": "Defined in pixels. Do not add the 'px' unit."
    },
    {
      "type": "text",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "info": "Defined in pixels. Do not add the 'px' unit."
    }
  ],
  "presets": [
    {
      "name": "VIDEO COUNTDOWN V2",
      "category": "HOME"
    }
  ]
}
{% endschema %}


